{
   "extends": "@tooling/typescript/core.json",
   "compilerOptions": {
      "composite": false,
      "noEmit": true,
      "paths": {
         "@core/agents": ["../../core/agents/src/agent.ts"],
         "@core/agents/*": ["../../core/agents/src/*"],
         "@core/database": ["../../core/database/src/index.ts"],
         "@core/database/*": ["../../core/database/src/*"],
         "@core/environment/worker": ["../../core/environment/src/worker.ts"],
         "@core/environment/*": ["../../core/environment/src/*"],
         "@core/logging": ["../../core/logging/src/logger.ts"],
         "@core/logging/*": ["../../core/logging/src/*"],
         "@core/posthog/*": ["../../core/posthog/src/*"],
         "@core/redis/*": ["../../core/redis/src/*"],
         "@core/stripe": ["../../core/stripe/src/index.ts"],
         "@core/stripe/*": ["../../core/stripe/src/*"],
         "@core/transactional/*": ["../../core/transactional/dist/*"],
         "@modules/billing/*": ["../../modules/billing/src/*"],
         "@packages/workflows/*": ["../../packages/workflows/src/*"],
         "@packages/events/*": ["../../packages/events/src/*"],
         "@packages/notifications/*": ["../../packages/notifications/src/*"]
      }
   },
   "include": ["src"],
   "references": [
      {
         "path": "../../packages/workflows"
      },
      {
         "path": "../../core/stripe"
      },
      {
         "path": "../../core/redis"
      },
      {
         "path": "../../core/posthog"
      },
      {
         "path": "../../core/logging"
      },
      {
         "path": "../../core/environment"
      },
      {
         "path": "../../core/database"
      }
   ]
}
