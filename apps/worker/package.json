{
   "name": "worker",
   "private": true,
   "type": "module",
   "scripts": {
      "build": "bun build src/index.ts --outdir dist --target bun --packages external",
      "start": "bun run dist/index.js",
      "dev": "dotenv -e ../web/.env.local -- bun run src/index.ts",
      "desktop:dev": "bun run dev",
      "typecheck": "tsgo"
   },
   "dependencies": {
      "@core/database": "workspace:*",
      "@core/dbos": "workspace:*",
      "@core/environment": "workspace:*",
      "@core/logging": "workspace:*",
      "@core/pg-boss": "workspace:*",
      "@core/posthog": "workspace:*",
      "@core/redis": "workspace:*",
      "@dbos-inc/dbos-sdk": "catalog:workers",
      "@modules/agents": "workspace:*",
      "@modules/cards": "workspace:*",
      "@modules/classification": "workspace:*",
      "@modules/workflows": "workspace:*",
      "better-result": "catalog:validation"
   },
   "devDependencies": {
      "@tooling/typescript": "workspace:*",
      "dotenv-cli": "catalog:environment",
      "typescript": "catalog:development"
   }
}
