{
   "$schema": "https://railway.app/railway.schema.json",
   "build": {
      "builder": "RAILPACK",
      "buildCommand": "NITRO_PRESET=bun bun run --filter=web build",
      "watchPatterns": [
         "/apps/web/",
         "/packages/**",
         "/core/**",
         "/libraries/**"
      ]
   },
   "deploy": {
      "startCommand": "bun apps/web/.output/server/index.mjs",
      "healthcheckPath": "/api/ping",
      "healthcheckTimeout": 60,
      "numReplicas": 1,
      "restartPolicyType": "ON_FAILURE",
      "restartPolicyMaxRetries": 10
   }
}
