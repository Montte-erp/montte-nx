{
   "extends": "@tooling/typescript/app.json",
   "compilerOptions": {
      "experimentalDecorators": true,
      "types": ["vite/client"],
      "verbatimModuleSyntax": false,
      "noUncheckedIndexedAccess": false,
      "noUncheckedSideEffectImports": true,
      "paths": {
         "@/*": ["./src/*"],
         "@core/authentication/*": ["../../core/authentication/src/*"],
         "@core/database": ["../../core/database/src/index.ts"],
         "@core/database/*": ["../../core/database/src/*"],
         "@core/dbos/*": ["../../core/dbos/src/*"],
         "@core/environment/*": ["../../core/environment/src/*"],
         "@core/files/*": ["../../core/files/src/*"],
         "@core/logging": ["../../core/logging/src/logger.ts"],
         "@core/logging/*": ["../../core/logging/src/*"],
         "@core/orpc/*": ["../../core/orpc/src/*"],
         "@core/notifications/*": ["../../core/notifications/src/*"],
         "@core/posthog/*": ["../../core/posthog/src/*"],
         "@core/redis/*": ["../../core/redis/src/*"],
         "@packages/ui/*": ["../../packages/ui/src/*"],
         "@modules/account/*": ["../../modules/account/src/*"],
         "@modules/agents/*": ["../../modules/agents/src/*"],
         "@modules/classification/*": ["../../modules/classification/src/*"],
         "@modules/finance/*": ["../../modules/finance/src/*"],
         "@modules/inbox/*": ["../../modules/inbox/src/*"]
      }
   },
   "include": ["src", "__tests__"],
   "references": [
      {
         "path": "../../packages/ui"
      },
      {
         "path": "../../core/redis"
      },
      {
         "path": "../../core/posthog"
      },
      {
         "path": "../../core/notifications"
      },
      {
         "path": "../../core/logging"
      },
      {
         "path": "../../core/files"
      },
      {
         "path": "../../core/environment"
      },
      {
         "path": "../../core/dbos"
      },
      {
         "path": "../../core/database"
      }
   ]
}
