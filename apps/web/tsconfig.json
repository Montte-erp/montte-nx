{
   "extends": "@tooling/typescript/app.json",
   "compilerOptions": {
      "types": ["vite/client"],
      "verbatimModuleSyntax": false,
      "noUncheckedIndexedAccess": false,
      "noUncheckedSideEffectImports": true,
      "paths": {
         "@/*": ["./src/*"],
         "@packages/ui/*": ["../../packages/ui/src/*"]
      }
   },
   "include": ["src", "__tests__"],
   "references": [
      {
         "path": "../../core/transactional"
      },
      {
         "path": "../../packages/feedback"
      },
      {
         "path": "../../packages/analytics"
      },
      {
         "path": "../../core/utils"
      },
      {
         "path": "../../core/stripe"
      },
      {
         "path": "../../core/redis"
      },
      {
         "path": "../../core/posthog"
      },
      {
         "path": "../../core/logging"
      },
      {
         "path": "../../core/files"
      },
      {
         "path": "../../core/environment"
      },
      {
         "path": "../../core/authentication"
      },
      {
         "path": "../../packages/ui"
      },
      {
         "path": "../../packages/events"
      },
      {
         "path": "../../packages/agents"
      },
      {
         "path": "../../core/database"
      }
   ]
}
