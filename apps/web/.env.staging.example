# ─── Staging environment ─────────────────────────────────────────────────────
# Copy this file to .env.staging.local and fill in your staging cloud values.
# Run with: bun dev:staging
#
# Unlike local dev, staging connects to real cloud services.
# No local containers needed.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@your-staging-db-host:5432/montte_staging

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://your-staging-redis-host:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=your-staging-auth-secret
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your-staging-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-staging-webhook-secret
STRIPE_BOOST_PRICE_ID=
STRIPE_SCALE_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ─── PostHog ─────────────────────────────────────────────────────────────────
POSTHOG_HOST=https://app.posthog.com
POSTHOG_KEY=phc_your-staging-posthog-key
POSTHOG_PUBLIC_KEY=phx_your-staging-posthog-public-key
POSTHOG_PROJECT_ID=your-staging-posthog-project-id
VITE_POSTHOG_HOST=https://app.posthog.com
VITE_POSTHOG_KEY=phc_your-staging-posthog-key

# ─── Email ───────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-staging-resend-key

# ─── Storage ─────────────────────────────────────────────────────────────────
AWS_ENDPOINT_URL=your-staging-s3-endpoint
AWS_S3_BUCKET_NAME=montte-documents
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-staging-access-key
AWS_SECRET_ACCESS_KEY=your-staging-secret-key

# ─── AI (optional) ───────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
TAVILY_API_KEYS=
EXA_API_KEYS=
FIRECRAWL_API_KEYS=

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
