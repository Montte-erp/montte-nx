# ─── Database ────────────────────────────────────────────────────────────────
# Matches apps/web/docker-compose.yml defaults
DATABASE_URL=postgresql://postgres:password@localhost:5432/montte

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
# DO NOT use this secret in production — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=local-dev-secret-change-me-in-production-32c
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000
# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Placeholder values let the app start; Google login won't work until replaced
BETTER_AUTH_GOOGLE_CLIENT_ID=placeholder-google-client-id
BETTER_AUTH_GOOGLE_CLIENT_SECRET=placeholder-google-client-secret

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/test/apikeys
# Placeholder values let the app start; payments won't work until replaced
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_BOOST_PRICE_ID=
STRIPE_SCALE_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ─── PostHog ─────────────────────────────────────────────────────────────────
# Get from https://app.posthog.com/project/settings
# Placeholder values let the app start; analytics won't work until replaced
POSTHOG_HOST=https://app.posthog.com
POSTHOG_KEY=phc_placeholder
POSTHOG_PUBLIC_KEY=phx_placeholder
POSTHOG_PROJECT_ID=placeholder
VITE_POSTHOG_HOST=https://app.posthog.com
VITE_POSTHOG_KEY=phc_placeholder

# ─── Email ───────────────────────────────────────────────────────────────────
# Get from https://resend.com/api-keys
# Placeholder value lets the app start; emails won't send until replaced
RESEND_API_KEY=re_placeholder

# ─── Storage (MinIO) ─────────────────────────────────────────────────────────
# Matches apps/web/docker-compose.yml defaults
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=montte-documents

# ─── AI (optional) ───────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
TAVILY_API_KEYS=
EXA_API_KEYS=
FIRECRAWL_API_KEYS=

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
