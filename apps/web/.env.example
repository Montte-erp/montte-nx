# ─── Database ────────────────────────────────────────────────────────────────
# Matches apps/web/docker-compose.yml defaults
DATABASE_URL=postgresql://postgres:password@localhost:5432/montte

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
# DO NOT use this secret in production — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=local-dev-secret-change-me-in-production-32c
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# ─── PostHog ─────────────────────────────────────────────────────────────────
# Get from https://app.posthog.com/project/settings
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_KEY=phc_placeholder
POSTHOG_PERSONAL_API_KEY=phx_placeholder

# ─── Logos ───────────────────────────────────────────────────────────────────
# Get from https://logo.dev
LOGO_DEV_TOKEN=logo_dev_placeholder

# ─── Email ───────────────────────────────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_placeholder

# ─── Storage (S3-compatible) ─────────────────────────────────────────────────
# Matches apps/web/docker-compose.yml defaults (RustFS)
AWS_ENDPOINT_URL=http://localhost:9000
AWS_S3_BUCKET_NAME=montte-documents
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=rustfsadmin
AWS_SECRET_ACCESS_KEY=rustfsadmin123

# ─── Vault ───────────────────────────────────────────────────────────────────
# DO NOT use this secret in production — generate with: openssl rand -base64 32
MONTTE_VAULT_MASTER_KEY=local-dev-vault-master-key-32!!!

# ─── AI (optional) ───────────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
