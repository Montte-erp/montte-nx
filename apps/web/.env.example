# ─── Database ────────────────────────────────────────────────────────────────
# Docker default (matches apps/web/docker-compose.yml)
DATABASE_URL=postgresql://postgres:password@localhost:5432/montte

# ─── Redis ───────────────────────────────────────────────────────────────────
# Docker default
REDIS_URL=redis://localhost:6379

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-generate-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
BETTER_AUTH_GOOGLE_CLIENT_ID=your-google-client-id
BETTER_AUTH_GOOGLE_CLIENT_SECRET=your-google-client-secret

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
# Get from https://dashboard.stripe.com/test/webhooks (use Stripe CLI for local)
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret
STRIPE_BOOST_PRICE_ID=
STRIPE_SCALE_PRICE_ID=
STRIPE_ENTERPRISE_PRICE_ID=

# ─── PostHog ─────────────────────────────────────────────────────────────────
# Get from https://app.posthog.com/project/settings
POSTHOG_HOST=https://app.posthog.com
POSTHOG_KEY=phc_your-posthog-key
POSTHOG_PUBLIC_KEY=phx_your-posthog-public-key
POSTHOG_PROJECT_ID=your-posthog-project-id
VITE_POSTHOG_HOST=https://app.posthog.com
VITE_POSTHOG_KEY=phc_your-posthog-key

# ─── Email ───────────────────────────────────────────────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key

# ─── Storage (MinIO) ─────────────────────────────────────────────────────────
# Docker default (matches apps/web/docker-compose.yml)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=montte-documents

# ─── AI (optional) ───────────────────────────────────────────────────────────
OPENROUTER_API_KEY=
TAVILY_API_KEYS=
EXA_API_KEYS=
FIRECRAWL_API_KEYS=

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:3000
