# =============================================================================
# CLIENT ENVIRONMENT VARIABLES (Build Time - VITE_* prefix)
# =============================================================================
# These are embedded in the client bundle and publicly accessible

VITE_POSTHOG_HOST=https://us.i.posthog.com
VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# =============================================================================
# SERVER ENVIRONMENT VARIABLES (Runtime)
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/montte
PG_VECTOR_URL=postgresql://user:password@localhost:5432/montte_vectors
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Authentication (Required)
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=your-secret-key-min-32-characters-long-xxxxxxxxxxxxx
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000,https://yourdomain.com
# BETTER_AUTH_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# BETTER_AUTH_GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Analytics (Required)
# -----------------------------------------------------------------------------
POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
POSTHOG_PROJECT_ID=12345
POSTHOG_PERSONAL_API_KEY=phx_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# POSTHOG_PUBLIC_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# File Storage (Required)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=montte-documents

# -----------------------------------------------------------------------------
# Payments (Optional - Stripe)
# -----------------------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_BOOST_PRICE_ID=price_xxx                                                                                                                                                                                               
STRIPE_SCALE_PRICE_ID=price_xxx                                                                                                                                                                                               
STRIPE_ENTERPRISE_PRICE_ID=price_xxx                                                                                                                                                                                          

# -----------------------------------------------------------------------------
# Email (Optional - Resend)
# -----------------------------------------------------------------------------
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# AI Services (Optional)
# -----------------------------------------------------------------------------
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TAVILY_API_KEYS=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EXA_API_KEYS=exa_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# FIRECRAWL_API_KEYS=fc-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Security (Optional - Arcjet)
# -----------------------------------------------------------------------------
# ARCJET_KEY=ajkey_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# ARCJET_ENV=development

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
NODE_ENV=development
# APP_URL=http://localhost:3000
# SERVER_URL=http://localhost:9876
LOG_LEVEL=info
# LOGTAIL_ENDPOINT=https://in.logtail.com
# LOGTAIL_SOURCE_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
