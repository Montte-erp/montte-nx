{
   "$schema": "https://schema.tauri.app/config/2",
   "productName": "Montte",
   "version": "0.2.0",
   "identifier": "br.com.montte.desktop",
   "build": {
      "beforeDevCommand": "bun run dev",
      "devUrl": "http://localhost:3000",
      "beforeBuildCommand": "bun run build",
      "frontendDist": "../.output/public"
   },
   "app": {
      "windows": [
         {
            "label": "main",
            "title": "Montte",
            "width": 1280,
            "height": 800,
            "minWidth": 1024,
            "minHeight": 700,
            "resizable": true
         }
      ],
      "security": {
         "csp": null
      }
   },
   "bundle": {
      "active": true,
      "targets": "all",
      "category": "Business",
      "icon": ["icons/icon.png"],
      "shortDescription": "Montte",
      "longDescription": "Montte desktop shell for the web app."
   }
}
