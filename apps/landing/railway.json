{
   "$schema": "https://railway.com/railway.schema.json",
   "build": {
      "builder": "RAILPACK",
      "buildCommand": "bun run landing:build",
      "watchPatterns": [
         "apps/landing/**",
         "packages/ui/**",
         "core/logging/**",
         "core/utils/**",
         "tooling/css/**",
         "tooling/typescript/**",
         "package.json",
         "bun.lock"
      ]
   },
   "deploy": {
      "startCommand": "bun run landing:start",
      "numReplicas": 1,
      "sleepApplication": true,
      "restartPolicyType": "ON_FAILURE",
      "restartPolicyMaxRetries": 10
   }
}
