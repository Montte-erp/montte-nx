---
import { PUBLIC_POSTHOG_HOST } from "astro:env/client";
---

<link rel="preconnect" href={PUBLIC_POSTHOG_HOST} />
<link rel="dns-prefetch" href={PUBLIC_POSTHOG_HOST} />
<script>
   import {
      PUBLIC_POSTHOG_HOST,
      PUBLIC_POSTHOG_KEY,
   } from "astro:env/client";
   import posthog from "posthog-js";

   const consent = localStorage.getItem("montte:cookie-consent");

   posthog.init(PUBLIC_POSTHOG_KEY, {
      api_host: PUBLIC_POSTHOG_HOST,
      defaults: "2026-01-30",
      opt_out_capturing_by_default: consent === '"rejected"',
      person_profiles: "always",
      capture_pageview: true,
      capture_pageleave: true,
      capture_exceptions: true,
      capture_dead_clicks: false,
      autocapture: true,
      capture_performance: { web_vitals: true },
      disable_session_recording: true,
      disable_surveys: true,
      disable_external_dependency_loading: true,
      enable_heatmaps: false,
      rageclick: false,
      opt_in_site_apps: false,
   });

   window.posthog = posthog;
</script>
