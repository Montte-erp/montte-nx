---
const PUBLIC_POSTHOG_HOST = import.meta.env.PUBLIC_POSTHOG_HOST;
---

<link rel="preconnect" href={PUBLIC_POSTHOG_HOST} />
<link rel="dns-prefetch" href={PUBLIC_POSTHOG_HOST} />
<script>
   import posthog from "posthog-js";

   const consent = localStorage.getItem("montte:cookie-consent");

   posthog.init(import.meta.env.PUBLIC_POSTHOG_KEY, {
      api_host: import.meta.env.PUBLIC_POSTHOG_HOST,
      defaults: "2026-01-30",
      opt_out_capturing_by_default: consent === '"rejected"',
      person_profiles: "always",
      capture_pageview: true,
      capture_pageleave: true,
      capture_exceptions: true,
      capture_dead_clicks: true,
      autocapture: true,
      capture_performance: { web_vitals: true },
      session_recording: {
         maskAllInputs: false,
         maskInputOptions: { password: true, email: true },
      },
      enable_heatmaps: true,
      rageclick: true,
      opt_in_site_apps: true,
   });

   window.posthog = posthog;
</script>
