---
export const prerender = true;
import BaseLayout from "../layouts/base-layout.astro";
import { HeroCarousel } from "../blocks/hero-carousel";
import SocialProofBlock from "../blocks/social-proof-block.astro";
import OperationsPillarsBlock from "../blocks/operations-pillars-block.astro";
import WaitlistBlock from "../blocks/waitlist-block.astro";
import FooterBlock from "../blocks/footer-block.astro";
---

<BaseLayout
   title="Montte: infraestrutura AI-native para serviços recorrentes"
   description="Cobrança, clientes, uso, pendências e financeiro em uma infraestrutura fácil de implementar para SaaS, coworkings e serviços recorrentes."
>
   <section
      class="relative isolate flex min-h-screen flex-col overflow-hidden"
      aria-label="Apresentação"
   >
      <video
         class="absolute inset-0 -z-30 size-full object-cover motion-reduce:hidden"
         autoplay
         muted
         loop
         playsinline
         preload="metadata"
         aria-hidden="true"
      >
         <source src="/videos/montte-hero-bg.webm" type="video/webm" />
      </video>
      <div
         class="absolute inset-0 -z-20 bg-gradient-to-r from-background/40 via-background/10 to-transparent"
         aria-hidden="true"
      >
      </div>
      <div
         class="absolute inset-x-0 bottom-0 -z-10 h-32 bg-gradient-to-b from-transparent to-background"
         aria-hidden="true"
      >
      </div>

      <div class="flex w-full flex-1 flex-col justify-center gap-4">
         <HeroCarousel client:idle />
      </div>
   </section>

   <SocialProofBlock />
   <OperationsPillarsBlock />
   <WaitlistBlock />

   <FooterBlock />
</BaseLayout>
