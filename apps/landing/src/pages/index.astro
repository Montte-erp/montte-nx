---
import BaseLayout from "../layouts/base-layout.astro";
---

<BaseLayout title="Montte" description="Montte">
   <main class="grid min-h-screen  text-foreground lg:grid-cols-[minmax(0,1fr)_minmax(0,64rem)_minmax(0,1fr)]">
      <aside class="hidden bg-accent lg:block" aria-hidden="true"></aside>

      <div class="bg-background">
         <header class="grid min-h-16 border-b border-border bg-background/80 px-4 backdrop-blur">
            <div class="flex w-full max-w-6xl items-center justify-between justify-self-center">
               <a class="inline-flex size-8 items-center justify-center rounded-lg border border-border bg-card text-primary" href="/" aria-label="Montte">
                  <img class="size-6" src="/favicon.svg" alt="" />
               </a>
            </div>
         </header>

         <section class="grid min-h-[calc(100vh-4rem)] px-4 py-4" aria-label="Montte">
            <div class="grid w-full max-w-6xl place-items-center justify-self-center">
               <img class="w-24 max-w-full text-primary" src="/favicon.svg" alt="Montte" />
            </div>
         </section>
      </div>

      <aside class="hidden bg-accent lg:block" aria-hidden="true"></aside>
   </main>
</BaseLayout>
