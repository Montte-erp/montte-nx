---
export const prerender = true;
import BaseLayout from "../layouts/base-layout.astro";
import { ArrowRight } from "@lucide/astro";
import { Button } from "@packages/ui/components/button";
import { AnimatedTexture } from "../components/animated-texture";
import { HeroCarousel } from "../blocks/hero-carousel";
import SocialProofBlock from "../blocks/social-proof-block.astro";
import OperationsPillarsBlock from "../blocks/operations-pillars-block.astro";
import WaitlistBlock from "../blocks/waitlist-block.astro";
import FooterBlock from "../blocks/footer-block.astro";
---

<BaseLayout
   title="Montte: recorrência e billing para SaaS brasileiros"
   description="Conecte assinatura, uso, cobrança, cliente e financeiro em uma operação recorrente feita para SaaS brasileiros."
>
   <section
      class="relative isolate flex min-h-screen flex-col overflow-hidden"
      aria-label="Apresentação"
   >
      <div
         class="absolute inset-0 -z-20"
         style="background: linear-gradient(to bottom, color-mix(in oklch, var(--secondary) 35%, var(--background)) 0%, color-mix(in oklch, var(--background) 88%, var(--secondary)) 42%, var(--background) 100%);"
         aria-hidden="true"
      >
      </div>
      <AnimatedTexture section="hero" client:load />
      <div
         class="absolute inset-x-0 bottom-0 -z-10 h-32 bg-gradient-to-b from-transparent to-background"
         aria-hidden="true"
      >
      </div>

      <div class="mx-auto flex w-full max-w-7xl flex-1 flex-col items-center justify-center gap-4 overflow-hidden px-2 py-4 sm:px-4">
         <HeroCarousel client:load />

         <div class="flex flex-wrap items-center justify-center gap-2">
            <a href="#waitlist" data-ph-cta="hero_waitlist">
               <Button size="lg" variant="default">
                  Quero acesso antecipado
                  <ArrowRight data-icon="inline-end" aria-hidden="true" />
               </Button>
            </a>
         </div>
      </div>
   </section>

   <SocialProofBlock />
   <OperationsPillarsBlock />
   <WaitlistBlock />

   <FooterBlock />
</BaseLayout>
