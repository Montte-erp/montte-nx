---
import { SocialProofMarquee } from "../components/social-proof-marquee";
---

<section
   class="flex min-h-[20vh] flex-col justify-center bg-transparent sm:min-h-[15vh]"
   aria-label="Cliente"
>
   <div class="mx-auto flex w-full max-w-7xl flex-col items-center gap-8 px-2 sm:px-4">
      <p class="text-center text-sm text-muted-foreground/70">
         Em pilotos com empresas brasileiras de verdade
      </p>
      <SocialProofMarquee client:visible />
   </div>
</section>
