---
import { Picture } from "astro:assets";
---

<section
   class="flex min-h-[15vh] flex-col justify-center bg-transparent"
   aria-label="Cliente"
>
   <div class="mx-auto flex w-full max-w-7xl flex-col items-center gap-8 px-4 sm:px-4">
      <p class="text-center text-sm text-muted-foreground/70">
         Em pilotos com empresas brasileiras de verdade
      </p>
      <div class="flex items-center justify-center">
         <a
            href="https://licitei.com.br"
            target="_blank"
            rel="noreferrer"
            class="opacity-70 grayscale transition hover:opacity-100 hover:grayscale-0"
            aria-label="Licitei"
         >
            <Picture
               src="/logos/licitei.svg"
               alt="Licitei"
               width={102}
               height={22}
               formats={["svg"]}
               fallbackFormat="svg"
               loading="lazy"
               decoding="async"
               class="h-8 w-auto"
            />
         </a>
      </div>
   </div>
</section>
