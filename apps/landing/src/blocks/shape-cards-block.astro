---
const cards = [
   {
      label: "Financeiro",
      title: "Fluxo de caixa em tempo real",
      desc: "Conciliação automática, OFX, Pix e cobranças recorrentes.",
   },
   {
      label: "Contatos",
      title: "CRM brasileiro de verdade",
      desc: "CPF, CNPJ, segmentação por centro de custo, importação CSV.",
   },
   {
      label: "Serviços",
      title: "Cobrança baseada em uso",
      desc: "Medidores, planos, addons e faturamento automatizado.",
   },
   {
      label: "IA Rubi",
      title: "Sua agente operacional",
      desc: "Categoriza, sugere, executa. Escreve relatórios sozinha.",
   },
];
---

<section class="mx-auto max-w-7xl px-4 pb-24 sm:px-6" aria-label="Módulos">
   <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {
         cards.map((c, i) => (
            <article class="group relative overflow-hidden rounded-2xl border border-border/60 bg-card/40 p-6 backdrop-blur transition-all hover:border-primary/40 hover:bg-card/70">
               <div class="relative flex aspect-square items-center justify-center overflow-hidden rounded-xl bg-gradient-to-br from-background/80 to-background/20 ring-1 ring-border/40">
                  <svg
                     class="size-2/3 text-primary/60 transition-transform duration-700 ease-out group-hover:scale-110 group-hover:rotate-12"
                     viewBox="0 0 200 200"
                     fill="none"
                     stroke="currentColor"
                     stroke-width="0.6"
                     aria-hidden="true"
                  >
                     {i === 0 &&
                        Array.from({ length: 16 }).map((_, k) => (
                           <line
                              x1="100"
                              y1="40"
                              x2="100"
                              y2="20"
                              transform={`rotate(${k * 22.5} 100 100)`}
                              class="origin-center animate-pulse"
                              style={`animation-delay:${k * 80}ms`}
                           />
                        ))}
                     {i === 1 &&
                        Array.from({ length: 24 }).map((_, k) => (
                           <line
                              x1="100"
                              y1="100"
                              x2="100"
                              y2={k % 2 === 0 ? "30" : "45"}
                              transform={`rotate(${k * 15} 100 100)`}
                              class="origin-center"
                           />
                        ))}
                     {i === 2 && (
                        <>
                           <circle cx="100" cy="100" r="70" />
                           <circle cx="100" cy="100" r="50" />
                           <circle cx="100" cy="100" r="30" />
                           <circle
                              cx="170"
                              cy="100"
                              r="3"
                              fill="currentColor"
                           />
                        </>
                     )}
                     {i === 3 && (
                        <>
                           <circle cx="100" cy="100" r="60" />
                           <path d="M100 40 Q140 100 100 160 Q60 100 100 40 Z" />
                           <circle
                              cx="100"
                              cy="100"
                              r="6"
                              fill="currentColor"
                           />
                        </>
                     )}
                  </svg>
                  <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-card/40 to-transparent" />
               </div>
               <div class="mt-5 flex flex-col gap-1.5">
                  <span class="text-xs font-medium tracking-wider text-primary uppercase">
                     {c.label}
                  </span>
                  <h3 class="text-base font-semibold text-foreground">
                     {c.title}
                  </h3>
                  <p class="text-sm leading-relaxed text-muted-foreground">
                     {c.desc}
                  </p>
               </div>
            </article>
         ))
      }
   </div>
</section>
