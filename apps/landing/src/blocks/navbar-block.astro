---
import { Button } from "@packages/ui/components/button";

import { ThemeSwitcherClient } from "./theme-switcher-client";

const navItems = [
   {
      title: "Produto",
      href: "/produto",
   },
   {
      title: "Preços",
      href: "/precos",
   },
   {
      title: "Docs",
      href: "/docs",
   },
   {
      title: "Contato",
      href: "/contato",
   },
];
---

<header class="shrink-0 border-b border-border bg-background/95 p-2 backdrop-blur">
   <nav class="flex min-h-10 items-center justify-between gap-4" aria-label="Principal">
      <div class="flex items-center gap-4">
          <a class="inline-flex items-center gap-2 rounded-md text-sm font-semibold text-foreground hover:text-primary" href="/" aria-label="Montte">
             <span class="inline-flex size-8 items-center justify-center rounded-md border border-border bg-card shadow-sm">
                <img class="size-4" src="/favicon.svg" alt="" />
             </span>
             <span>Montte</span>
          </a>

          <div class="hidden items-center gap-2 md:flex">
             {
                navItems.map((item) => (
                   <a
                      class="rounded-md px-2 py-2 text-sm text-muted-foreground transition-colors hover:bg-accent hover:text-accent-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring"
                      href={item.href}
                   >
                      {item.title}
                   </a>
                ))
             }
          </div>
       </div>

      <div class="flex items-center gap-2">
          <Button asChild size="sm">
             <a href="/dashboard">Entrar</a>
          </Button>
          <ThemeSwitcherClient client:load />
      </div>
   </nav>
</header>
