---
import { Picture } from "astro:assets";
---

<header
   id="site-navbar"
   class="pointer-events-none fixed inset-x-0 top-4 z-40 -translate-y-full opacity-0 transition-[opacity,transform] duration-300 data-[scrolled=true]:pointer-events-auto data-[scrolled=true]:translate-y-0 data-[scrolled=true]:opacity-100"
   data-scrolled="false"
>
   <nav
      class="mx-auto flex max-w-7xl items-center justify-center px-4 sm:px-4"
      aria-label="Principal"
   >
      <a
         class="inline-flex size-12 items-center justify-center rounded-full border border-border/40 bg-background/70 shadow-lg shadow-background/30 backdrop-blur-xl"
         href="/"
         aria-label="Montte"
      >
         <Picture
            src="/favicon.svg"
            alt=""
            width={28}
            height={28}
            formats={["svg"]}
            fallbackFormat="svg"
            loading="eager"
            decoding="async"
         />
      </a>
   </nav>
</header>

<script>
   const nav = document.getElementById("site-navbar");
   if (nav) {
      const update = () => {
         nav.dataset.scrolled = window.scrollY > 64 ? "true" : "false";
      };
      update();
      window.addEventListener("scroll", update, { passive: true });
   }
</script>
