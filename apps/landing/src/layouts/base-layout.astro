---
import "@tooling/css/globals.css";

import NavbarBlock from "../blocks/navbar-block.astro";
import { PostHogClient } from "../components/posthog-client";

interface Props {
   description: string;
   title: string;
}

const { description, title } = Astro.props;
---

<!doctype html>
<html lang="pt-BR" class="dark">
   <head>
      <meta charset="UTF-8" />
      <meta name="description" content={description} />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <meta name="robots" content="index,follow" />
      <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
      <link rel="canonical" href={Astro.url.href} />
      <meta property="og:type" content="website" />
      <meta property="og:title" content={title} />
      <meta property="og:description" content={description} />
      <meta property="og:url" content={Astro.url.href} />
      <meta property="og:image" content="/favicon.svg" />
      <meta property="og:locale" content="pt_BR" />
      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:title" content={title} />
      <meta name="twitter:description" content={description} />
      <meta name="twitter:image" content="/favicon.svg" />
      <title>{title}</title>
   </head>
   <body class="relative min-h-dvh bg-background text-foreground antialiased">
      <PostHogClient client:load />
      <NavbarBlock />
      <main class="relative">
         <slot />
      </main>
   </body>
</html>
