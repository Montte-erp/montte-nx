---
import "@tooling/css/globals.css";

import PostHog from "../components/posthog.astro";
import { CookieConsent } from "../components/cookie-consent";
import NavbarBlock from "../blocks/navbar-block.astro";

interface Props {
   description: string;
   title: string;
}

const { description, title } = Astro.props;
const siteUrl = "https://montte.co";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl);
const canonical = canonicalUrl.toString();
const socialImage = new URL("/favicon.svg", siteUrl).toString();
const jsonLd = JSON.stringify({
   "@context": "https://schema.org",
   "@type": "Organization",
   name: "Montte",
   url: siteUrl,
   logo: new URL("/favicon.svg", siteUrl).toString(),
   sameAs: ["https://github.com/Montte-erp/montte-nx"],
});
---

<!doctype html>
<html lang="pt-BR" class="dark">
   <head>
      <meta charset="UTF-8" />
      <meta name="description" content={description} />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <meta name="robots" content="index,follow" />
      <meta name="author" content="Montte" />
      <meta name="application-name" content="Montte" />
      <meta name="theme-color" content="#0c5343" />
      <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
      <link rel="canonical" href={canonical} />
      <link rel="preconnect" href="https://fonts.googleapis.com" />
      <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
      <link
         rel="stylesheet"
         href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap"
      />
      <meta property="og:type" content="website" />
      <meta property="og:site_name" content="Montte" />
      <meta property="og:title" content={title} />
      <meta property="og:description" content={description} />
      <meta property="og:url" content={canonical} />
      <meta property="og:image" content={socialImage} />
      <meta property="og:image:alt" content="Montte" />
      <meta property="og:locale" content="pt_BR" />
      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:title" content={title} />
      <meta name="twitter:description" content={description} />
      <meta name="twitter:image" content={socialImage} />
      <title>{title}</title>
      <script is:inline type="application/ld+json" set:html={jsonLd} />
      <PostHog />
   </head>
   <body class="relative min-h-dvh bg-background text-foreground antialiased">
      <NavbarBlock />
      <main class="relative">
         <slot />
      </main>
      <CookieConsent client:load />
   </body>
</html>
