---
import "@tooling/css/globals.css";

import { ShapeGridAside } from "../components/shape-grid";
import NavbarBlock from "../blocks/navbar-block.astro";

interface Props {
   description: string;
   title: string;
}

const { description, title } = Astro.props;
---

<!doctype html>
<html lang="pt-BR">
   <head>
      <meta charset="UTF-8" />
      <meta name="description" content={description} />
      <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
      <title>{title}</title>
   </head>
   <body class="overflow-hidden">
      <main class="flex h-dvh text-foreground">
         <ShapeGridAside client:load />

         <div class="flex h-dvh w-full max-w-7xl shrink-0 flex-col bg-background">
            <NavbarBlock />
            <div class="min-h-0 flex-1 overflow-y-auto">
               <slot />
            </div>
         </div>

         <ShapeGridAside client:load />
      </main>
   </body>
</html>
