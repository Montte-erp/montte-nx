{
   "$schema": "https://railway.com/railway.schema.json",
   "build": {
      "builder": "RAILPACK",
      "buildCommand": "bun run --filter=sdk-server build",
      "watchPatterns": ["/apps/sdk-server/**", "/packages/**", "/libraries/**"]
   },
   "deploy": {
      "startCommand": "bun run --filter=sdk-server start",
      "multiRegionConfig": {
         "us-east4-eqdc4a": {
            "numReplicas": 1
         }
      },
      "numReplicas": 1,
      "restartPolicyMaxRetries": 10,
      "restartPolicyType": "ON_FAILURE",
      "runtime": "V2",
      "sleepApplication": false
   }
}
