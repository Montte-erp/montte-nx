---
import "@packages/ui/globals.css";

import { VITE_POSTHOG_HOST, VITE_POSTHOG_KEY, VITE_POSTHOG_UI_HOST } from "astro:env/client";
import { getAstroPosthogConfig } from "@packages/posthog/client";

const brandName = "Montte";
const brandDescription = "Gestão financeira completa para você e seus negócios. Simples, transparente e Open Source.";

const posthogEnv = {
   VITE_POSTHOG_HOST,
   VITE_POSTHOG_KEY,
   VITE_POSTHOG_UI_HOST,
};
---

<!doctype html>
<html lang="pt-BR" class="scroll-smooth">
   <head>
      <!-- Dark mode detection - runs before page renders to prevent flash -->
      <script is:inline>
         (function() {
            const stored = localStorage.getItem('theme');
            const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
            
            if (stored === 'dark' || (!stored && prefersDark)) {
               document.documentElement.classList.add('dark');
            } else {
               document.documentElement.classList.remove('dark');
            }
         })();
      </script>
      
      <link rel="sitemap" href="/sitemap-index.xml">
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width">
      <meta
         name="description"
         content={`${brandDescription}`}
      >
      <meta
         name="title"
         content={brandName}
      >
      <meta
         name="keywords"
         content="gestão financeira, controle de gastos, orçamento pessoal, contas a pagar, contas a receber, open source, finanças, transações, importar OFX"
      >
      <meta name="author" content="Montte">
      <link rel="icon" type="image/svg+xml" href="/favicon.svg">
      <meta name="generator" content={Astro.generator}>
      <link rel="canonical" href="https://montte.co/">


      <meta property="og:title" content={brandName}>
      <meta
         property="og:description"
         content={brandDescription}
      >
      <meta property="og:image" content="/og-image.webp">
      <meta property="og:url" content="https://montte.co">
      <meta property="og:type" content="website">
      {import.meta.env.PROD && <script set:html={getAstroPosthogConfig(
         posthogEnv
      )}
      is:inline/>}
      <title>
         {brandName} - {brandDescription}
      </title>
   </head>
   <body>
      <slot/>
   </body>
</html>
