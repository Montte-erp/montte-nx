---
import { Briefcase, Building2, User, Users } from "@lucide/astro";
---

<section class="py-16 md:py-32">
	<div class="mx-auto max-w-7xl space-y-8 px-6 md:space-y-12">
		<!-- Header -->
		<div class="mx-auto max-w-xl space-y-6 text-center md:space-y-12">
			<span class="text-primary text-sm font-bold uppercase tracking-widest">
				Casos de Uso
			</span>
			<h2 class="text-balance text-4xl font-medium lg:text-5xl">
				Para quem é o Montte?
			</h2>
			<p class="text-muted-foreground">
				Desde finanças pessoais até controle empresarial, o Montte se adapta ao seu fluxo.
			</p>
		</div>

		<!-- 4-column grid -->
		<div class="relative mx-auto grid grid-cols-2 gap-x-3 gap-y-6 sm:gap-8 lg:grid-cols-4">
			<!-- Finanças Pessoais -->
			<div class="space-y-3">
				<div class="flex items-center gap-2">
					<User class="size-4 text-primary" />
					<h3 class="text-sm font-medium">Finanças Pessoais</h3>
				</div>
				<p class="text-muted-foreground text-sm">
					Acompanhe seus gastos, identifique para onde vai seu dinheiro.
				</p>
			</div>
			<!-- Freelancers -->
			<div class="space-y-3">
				<div class="flex items-center gap-2">
					<Briefcase class="size-4 text-primary" />
					<h3 class="text-sm font-medium">Freelancers</h3>
				</div>
				<p class="text-muted-foreground text-sm">
					Separe despesas pessoais das profissionais, organize para o IR.
				</p>
			</div>
			<!-- Pequenas Empresas -->
			<div class="space-y-3">
				<div class="flex items-center gap-2">
					<Building2 class="size-4 text-primary" />
					<h3 class="text-sm font-medium">Pequenas Empresas</h3>
				</div>
				<p class="text-muted-foreground text-sm">
					Controle fluxo de caixa e acompanhe despesas por centro de custo.
				</p>
			</div>
			<!-- Famílias -->
			<div class="space-y-3">
				<div class="flex items-center gap-2">
					<Users class="size-4 text-primary" />
					<h3 class="text-sm font-medium">Famílias</h3>
				</div>
				<p class="text-muted-foreground text-sm">
					Gerencie o orçamento familiar em conjunto, todos alinhados.
				</p>
			</div>
		</div>
	</div>
</section>
