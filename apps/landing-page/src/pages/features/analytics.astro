---
export const prerender = true;

import { FeatureCarousel } from "@/components/feature-carousel";
import CTA from "@/components/CTA.astro";
import Footer from "@/components/Footer.astro";
import StickyNavbar from "@/components/StickyNavbar.astro";
import Layout from "@/layouts/Landing.astro";

const features = [
   {
      id: "custom-dashboards",
      title: "Dashboards Personalizados",
      description: "Crie dashboards sob medida com widgets arrastáveis e templates prontos para começar rápido.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Dashboards+Personalizados",
      width: "wide" as const,
   },
   {
      id: "interactive-charts",
      title: "Gráficos Interativos",
      description: "Mais de 10 tipos de gráficos com drill-down, comparação entre períodos e filtros dinâmicos.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Graficos+Interativos",
      width: "narrow" as const,
   },
   {
      id: "pdf-export",
      title: "Exportação em PDF",
      description: "Exporte dashboards completos como PDFs profissionais para reuniões e auditorias.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Exportacao+PDF",
      width: "narrow" as const,
   },
   {
      id: "drill-down",
      title: "Drill-Down Inteligente",
      description: "Do resumo mensal até a transação individual com poucos cliques e filtros mantidos.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Drill-Down+Categorias",
      width: "narrow" as const,
   },
   {
      id: "widgets",
      title: "Widgets Customizáveis",
      description: "Diversos tipos de widgets redimensionáveis com configuração de cores, títulos e descrições.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Widgets+Customizaveis",
      width: "narrow" as const,
   },
];
---

<Layout>
   <div class="flex flex-col">
      <StickyNavbar />
      <section class="py-16 md:py-24">
         <FeatureCarousel
            items={features}
            badge="Analytics"
            title="Analytics e Relatórios Gerenciais"
            subtitle="Dashboards personalizados, relatórios DRE, gráficos interativos. Transforme dados em decisões estratégicas."
            ctaText="Começar Grátis"
            ctaHref="https://app.montte.co/auth/sign-up"
            benefitText="Ferramentas avançadas de análise com dashboards personalizáveis, gráficos interativos e exportação profissional em PDF."
            client:load
         />
      </section>
      <CTA />
      <Footer />
   </div>
</Layout>
