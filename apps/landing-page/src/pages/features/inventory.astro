---
export const prerender = true;

import CTA from "@/components/CTA.astro";
import Footer from "@/components/Footer.astro";
import FeatureDeepDive from "@/components/features/FeatureDeepDive.astro";
import FeatureHero from "@/components/features/FeatureHero.astro";
import StickyNavbar from "@/components/StickyNavbar.astro";
import Layout from "@/layouts/Landing.astro";
---

<Layout>
	<div class="flex flex-col bg-background">
		<StickyNavbar />

		<FeatureHero
			eyebrow="Inventário e Estoque"
			title="Inventário e Gestão de Estoque"
			description="Controle completo de produtos, materiais e ativos. Rastreamento em tempo real, avaliação FIFO/Média, alertas automáticos."
			image="https://placehold.co/1200x700/151925/22c55e?text=Tela+de+Contas"
			imageAlt="Visao geral da tela de contas a pagar e receber do Montte"
		/>

		<!-- Feature Deep Dives -->
		<FeatureDeepDive
			eyebrow="Controle Total"
			title="Rastreamento de Produtos"
			description="Cada item com código único (SKU), localização e histórico completo. Saiba exatamente o que tem, onde está e quanto vale em tempo real."
			image="https://placehold.co/600x400/151925/f59e0b?text=Rastreamento"
			imageAlt="Interface de rastreamento de produtos"
			bullets={[
				"SKU único por produto",
				"Múltiplas unidades de medida (kg, un, cx)",
				"Histórico completo de movimentações",
				"Classificação por tipo (produto, material, ativo)",
			]}
		/>

		<FeatureDeepDive
			eyebrow="Auditoria"
			title="Movimentações Detalhadas"
			description="Registro automático de entradas, saídas, transferências e ajustes. Auditoria completa de cada mudança no estoque com motivo e responsável."
			image="https://placehold.co/600x400/151925/f59e0b?text=Movimentacoes"
			imageAlt="Registro de movimentações de estoque"
			bullets={[
				"Entrada, saída, transferência, ajuste",
				"Motivo obrigatório para cada movimentação",
				"Vínculo opcional com transações financeiras",
				"Rastreamento de lotes e validade",
			]}
			reverse={true}
		/>

		<FeatureDeepDive
			eyebrow="Custos Precisos"
			title="Custeio FIFO e Médio"
			description="Cálculo automático de custos por FIFO (primeiro a entrar, primeiro a sair) ou média ponderada. Margem de lucro precisa em cada venda."
			image="https://placehold.co/600x400/151925/f59e0b?text=Custeio"
			imageAlt="Dashboard de custeio e valorização"
			bullets={[
				"Escolha entre FIFO ou média ponderada",
				"Cálculo automático em cada movimentação",
				"Suporte a múltiplas moedas",
				"Relatório de valorização de estoque",
			]}
		/>

		<FeatureDeepDive
			eyebrow="Inteligência"
			title="Alertas de Reposição"
			description="Notificações automáticas quando estoque atingir ponto de pedido. Nunca mais perca vendas por falta de produto com alertas configuráveis."
			image="https://placehold.co/600x400/151925/f59e0b?text=Alertas"
			imageAlt="Configuração de alertas de reposição"
			bullets={[
				"Ponto mínimo configurável por item",
				"Alertas por email e push",
				"Sugestão de quantidade a comprar",
				"Relatório de itens em falta",
			]}
			reverse={true}
		/>

		<FeatureDeepDive
			eyebrow="Fornecedores"
			title="Integração com Fornecedores"
			description="Conecte com fornecedores para pedidos automáticos. Catálogo de preços, prazos de entrega e histórico de compras tudo integrado."
			image="https://placehold.co/600x400/151925/f59e0b?text=Fornecedores"
			imageAlt="Catálogo de fornecedores e pricing"
			bullets={[
				"Catálogo de preços por fornecedor",
				"Prazo de entrega (lead time)",
				"Quantidade mínima de pedido (MOQ)",
				"Fornecedor padrão por item",
			]}
		/>

		<!-- Final CTA -->
		<CTA />

		<Footer />
	</div>
</Layout>
