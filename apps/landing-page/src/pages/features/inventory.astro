---
export const prerender = true;

import { FeatureCarousel } from "@/components/feature-carousel";
import CTA from "@/components/CTA.astro";
import Footer from "@/components/Footer.astro";
import StickyNavbar from "@/components/StickyNavbar.astro";
import Layout from "@/layouts/Landing.astro";

const features = [
   {
      id: "bills-payable",
      title: "Contas a Pagar",
      description: "Gerencie despesas futuras com lembretes automáticos, filtros por status e anexo de boletos.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Contas+a+Pagar",
      width: "narrow" as const,
   },
   {
      id: "bills-receivable",
      title: "Contas a Receber",
      description: "Acompanhe receitas previstas, identifique inadimplentes e projete recebimentos futuros.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Contas+a+Receber",
      width: "wide" as const,
   },
   {
      id: "installments",
      title: "Parcelamentos",
      description: "Controle compras parceladas e visualize todas as parcelas futuras com cálculo automático.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Parcelamentos",
      width: "narrow" as const,
   },
   {
      id: "recurring",
      title: "Contas Recorrentes",
      description: "Automatize lançamentos que se repetem (aluguel, assinaturas) com geração automática.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Contas+Recorrentes",
      width: "narrow" as const,
   },
   {
      id: "batch-payment",
      title: "Baixa em Lote",
      description: "Pague múltiplas contas de uma só vez com registro automático de transações.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Baixa+em+Lote",
      width: "narrow" as const,
   },
];
---

<Layout>
   <div class="flex flex-col">
      <StickyNavbar />
      <section class="py-16 md:py-24">
         <FeatureCarousel
            items={features}
            badge="Estoque"
            title="Inventário e Gestão de Estoque"
            subtitle="Controle completo de produtos, materiais e ativos. Rastreamento em tempo real, avaliação FIFO/Média, alertas automáticos."
            ctaText="Começar Grátis"
            ctaHref="https://app.montte.co/auth/sign-up"
            benefitText="Sistema completo de gestão de contas a pagar e receber com controle de parcelamentos, recorrências e pagamentos em lote."
            client:load
         />
      </section>
      <CTA />
      <Footer />
   </div>
</Layout>
