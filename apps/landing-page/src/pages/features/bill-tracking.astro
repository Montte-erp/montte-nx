---
export const prerender = true;

import StickyNavbar from "@/components/StickyNavbar.astro";
import Layout from "@/layouts/Landing.astro";
import Footer from "@/components/Footer.astro";
import CTA from "@/components/CTA.astro";
import UseCases from "@/components/UseCases.astro";
import FeatureDeepDive from "@/components/features/FeatureDeepDive.astro";
import FeatureHero from "@/components/features/FeatureHero.astro";
---

<Layout>
	<div class="flex flex-col bg-background">
		<StickyNavbar />

		<FeatureHero
			eyebrow="Contas a Pagar e Receber"
			title="Previsibilidade no seu fluxo de caixa."
			description="Saiba exatamente o que entra e o que sai do seu caixa nos proximos meses. Evite surpresas, multas por atraso e mantenha suas financas sempre em dia."
			image="https://placehold.co/1200x700/151925/22c55e?text=Tela+de+Contas"
			imageAlt="Visao geral da tela de contas a pagar e receber do Montte"
		/>

		<!-- Feature Deep Dives -->
		<FeatureDeepDive
			eyebrow="Contas a Pagar"
			title="Nunca mais perca um vencimento."
			description="Gerencie todas as suas despesas futuras em um so lugar. Filtre por status, categoria ou fornecedor e tenha visibilidade completa do que esta por vir. Receba lembretes antes do vencimento e evite multas e juros desnecessarios."
			image="https://placehold.co/600x400/151925/22c55e?text=Contas+a+Pagar"
			imageAlt="Lista de contas a pagar com filtros e status"
			bullets={[
				"Lembretes automaticos antes do vencimento",
				"Filtros por status, categoria e fornecedor",
				"Anexo de boletos e comprovantes",
				"Historico completo de pagamentos",
			]}
		/>

		<FeatureDeepDive
			eyebrow="Contas a Receber"
			title="Acompanhe suas receitas previstas com precisao."
			description="Visualize todas as suas receitas futuras e mantenha o controle do seu fluxo de caixa. Acompanhe clientes inadimplentes, envie lembretes de cobranca e tenha estatisticas de recebimentos para planejar melhor."
			image="https://placehold.co/600x400/151925/22c55e?text=Contas+a+Receber"
			imageAlt="Painel de contas a receber com estatisticas"
			bullets={[
				"Estatisticas de taxa de recebimento",
				"Identificacao de clientes inadimplentes",
				"Lembretes de cobranca automaticos",
				"Projecao de recebimentos futuros",
			]}
			reverse={true}
		/>

		<FeatureDeepDive
			eyebrow="Parcelamentos"
			title="Controle total sobre compras parceladas."
			description="Cadastre compras parceladas com facilidade e visualize todas as parcelas futuras. Saiba exatamente quanto esta comprometido nos proximos meses e tome decisoes conscientes antes de parcelar novamente."
			image="https://placehold.co/600x400/151925/22c55e?text=Parcelamentos"
			imageAlt="Gestao de compras parceladas e parcelas futuras"
			bullets={[
				"Cadastro rapido de parcelamentos",
				"Visualizacao de todas as parcelas futuras",
				"Calculo automatico do valor total",
				"Alerta de comprometimento de renda",
			]}
		/>

		<FeatureDeepDive
			eyebrow="Contas Recorrentes"
			title="Automatize lancamentos que se repetem."
			description="Configure contas que se repetem automaticamente - aluguel, assinaturas, mensalidades e mais. O sistema gera os lancamentos futuros sem esforco, liberando seu tempo para focar no que importa."
			image="https://placehold.co/600x400/151925/22c55e?text=Contas+Recorrentes"
			imageAlt="Configuracao de contas recorrentes"
			bullets={[
				"Frequencia flexivel (semanal, mensal, anual)",
				"Geracao automatica de lancamentos",
				"Reajuste programado de valores",
				"Pausa e retomada quando necessario",
			]}
			reverse={true}
		/>

		<FeatureDeepDive
			eyebrow="Baixa em Lote"
			title="Pague multiplas contas de uma so vez."
			description="Selecione varias contas vencidas ou a vencer e registre o pagamento em massa. Economize tempo no fechamento do mes e mantenha seus registros sempre atualizados sem esforco repetitivo."
			image="https://placehold.co/600x400/151925/22c55e?text=Baixa+em+Lote"
			imageAlt="Interface de baixa em lote de contas"
			bullets={[
				"Selecao multipla de contas",
				"Pagamento parcial ou total",
				"Registro de forma de pagamento",
				"Geracao automatica de transacoes",
			]}
		/>

		<!-- Use Cases -->
		<UseCases />

		<!-- Final CTA -->
		<CTA />

		<Footer />
	</div>
</Layout>
