---
export const prerender = true;

import { FeatureCarousel } from "@/components/feature-carousel";
import CTA from "@/components/CTA.astro";
import Footer from "@/components/Footer.astro";
import StickyNavbar from "@/components/StickyNavbar.astro";
import Layout from "@/layouts/Landing.astro";

const features = [
   {
      id: "quick-entry",
      title: "Entrada Rápida",
      description: "Adicione transações em segundos com atalhos de teclado, categorias inteligentes e formulários otimizados.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Lancamento+Rapido",
      width: "narrow" as const,
   },
   {
      id: "smart-split",
      title: "Rateio Inteligente",
      description: "Divida transações entre múltiplas categorias com valores fixos ou percentuais para relatórios precisos.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Rateio+de+Categorias",
      width: "narrow" as const,
   },
   {
      id: "attachments",
      title: "Anexos e Comprovantes",
      description: "Arraste e solte notas fiscais e recibos. Tudo organizado e pronto para auditoria.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Anexos+e+Comprovantes",
      width: "narrow" as const,
   },
   {
      id: "bank-import",
      title: "Importação Bancária",
      description: "Importe extratos CSV ou OFX de qualquer banco brasileiro com mapeamento automático.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Importacao+CSV+OFX",
      width: "wide" as const,
   },
   {
      id: "filters",
      title: "Filtros e Análise",
      description: "Filtros poderosos por período, categoria, conta e tags com estatísticas em tempo real.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Filtros+e+Estatisticas",
      width: "narrow" as const,
   },
];
---

<Layout>
   <div class="flex flex-col">
      <StickyNavbar />
      <section class="py-16 md:py-24">
         <FeatureCarousel
            items={features}
            badge="Gestão Financeira"
            title="Controle financeiro completo para seu negócio"
            subtitle="Das transações diárias aos relatórios fiscais. Gerencie receitas, despesas, contas a pagar e receber em um só lugar."
            ctaText="Começar Grátis"
            ctaHref="https://app.montte.co/auth/sign-up"
            benefitText="Sistema completo de gestão financeira com categorização inteligente, anexos de documentos e análise em tempo real."
            client:load
         />
      </section>
      <CTA />
      <Footer />
   </div>
</Layout>
