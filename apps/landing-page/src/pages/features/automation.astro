---
export const prerender = true;

import { FeatureCarousel } from "@/components/feature-carousel";
import CTA from "@/components/CTA.astro";
import Footer from "@/components/Footer.astro";
import StickyNavbar from "@/components/StickyNavbar.astro";
import Layout from "@/layouts/Landing.astro";

const features = [
   {
      id: "workspaces",
      title: "Múltiplas Organizações",
      description: "Gerencie finanças pessoais e empresariais em workspaces separados com alternância rápida.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Multiplas+Organizacoes",
      width: "narrow" as const,
   },
   {
      id: "team-invites",
      title: "Convites e Time",
      description: "Convide sócios e colaboradores com credenciais próprias e registro de auditoria completo.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Convites+e+Time",
      width: "wide" as const,
   },
   {
      id: "permissions",
      title: "Permissões Granulares",
      description: "Controle quem pode ver ou editar cada conta bancária com papéis predefinidos ou customizados.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Permissoes+por+Conta",
      width: "narrow" as const,
   },
   {
      id: "automation-rules",
      title: "Regras de Automação",
      description: "Categorização automática baseada em padrões com aplicação retroativa e sugestões inteligentes.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Automacoes",
      width: "narrow" as const,
   },
];
---

<Layout>
   <div class="flex flex-col">
      <StickyNavbar />
      <section class="py-16 md:py-24">
         <FeatureCarousel
            items={features}
            badge="Automação"
            title="Automação e Workflows Inteligentes"
            subtitle="Regras visuais, categorização automática, notificações e integrações. Elimine trabalho manual com automações que funcionam."
            ctaText="Começar Grátis"
            ctaHref="https://app.montte.co/auth/sign-up"
            benefitText="Automatize tarefas repetitivas com regras inteligentes, colabore com seu time e gerencie permissões de forma granular."
            client:load
         />
      </section>
      <CTA />
      <Footer />
   </div>
</Layout>
