---
export const prerender = true;

import { FeatureCarousel } from "@/components/feature-carousel";
import CTA from "@/components/CTA.astro";
import Footer from "@/components/Footer.astro";
import StickyNavbar from "@/components/StickyNavbar.astro";
import Layout from "@/layouts/Landing.astro";

const features = [
   {
      id: "budgets",
      title: "Orçamentos Flexíveis",
      description: "Crie orçamentos diários, semanais, mensais ou anuais com limites por categoria e rollover de saldo.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Orcamentos+por+Periodo",
      width: "narrow" as const,
   },
   {
      id: "realtime-progress",
      title: "Progresso em Tempo Real",
      description: "Acompanhe gastos com indicadores visuais por cor e projeções automáticas até o fim do período.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Progresso+Tempo+Real",
      width: "narrow" as const,
   },
   {
      id: "savings-goals",
      title: "Metas de Poupança",
      description: "Defina objetivos financeiros, acompanhe evolução e celebre marcos com visualizações motivadoras.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Metas+de+Poupanca",
      width: "wide" as const,
   },
   {
      id: "spending-limits",
      title: "Alertas de Limites",
      description: "Receba notificações quando se aproximar dos limites de gastos (50%, 75%, 90%, 100%).",
      image: "https://placehold.co/600x400/151925/22c55e?text=Limite+de+Gastos",
      width: "narrow" as const,
   },
   {
      id: "debt-payoff",
      title: "Quitação de Dívidas",
      description: "Planeje quitação de dívidas com estratégias bola de neve ou avalanche e simulação de pagamentos.",
      image: "https://placehold.co/600x400/151925/22c55e?text=Quitacao+de+Dividas",
      width: "narrow" as const,
   },
];
---

<Layout>
   <div class="flex flex-col">
      <StickyNavbar />
      <section class="py-16 md:py-24">
         <FeatureCarousel
            items={features}
            badge="Planejamento"
            title="Planejamento e Controle Empresarial"
            subtitle="Orçamentos, metas, centros de custo e previsões. Planeje o futuro do seu negócio com dados confiáveis."
            ctaText="Começar Grátis"
            ctaHref="https://app.montte.co/auth/sign-up"
            benefitText="Ferramentas completas de planejamento financeiro com orçamentos flexíveis, metas e controle de gastos em tempo real."
            client:load
         />
      </section>
      <CTA />
      <Footer />
   </div>
</Layout>
