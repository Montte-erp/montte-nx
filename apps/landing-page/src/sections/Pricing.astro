---
import {
   Building2,
   Check,
   Github,
   Rocket,
   Server,
   Sparkles,
   Users,
} from "@lucide/astro";
import { Button } from "@packages/ui/components/button";

const plans = [
   {
      name: "Free",
      icon: Server,
      tagline: "Para sempre",
      price: "R$0",
      period: "/mês",
      description:
         "Para começar a organizar suas finanças pessoais. 100% funcional, para sempre.",
      cta: "Comece Grátis",
      ctaHref: "/signup",
      ctaVariant: "outline" as const,
      selfHostOptions: true,
      features: [
         "1 usuário",
         "Categorias básicas",
         "Transações ilimitadas",
         "Relatórios básicos",
         "Importação OFX/CSV",
         "Exportação OFX/CSV/PDF",
         "50 MB de armazenamento",
      ],
      limitations: [
         "Sem tags",
         "Sem automações",
         "Sem centros de custo",
         "Apenas você no workspace",
      ],
   },
   {
      name: "Pessoal",
      icon: Sparkles,
      tagline: "Finanças pessoais",
      price: "R$15",
      period: "/mês",
      annualPrice: "ou R$150/ano (17% de desconto)",
      description: "Para quem quer mais controle sobre suas finanças pessoais.",
      cta: "Teste 14 Dias Grátis",
      ctaHref: "/signup?plan=basic",
      ctaVariant: "outline" as const,
      features: [
         "✨ Tudo do Free +",
         "Tags personalizáveis",
         "Mais opções de relatórios",
         "1 GB de armazenamento",
         "Suporte por email",
      ],
   },
   {
      name: "Compartilhado",
      icon: Users,
      tagline: "Casais e famílias",
      price: "R$25",
      period: "/mês",
      annualPrice: "ou R$250/ano (17% de desconto)",
      description:
         "Ideal para casais, noivos e famílias compartilharem finanças.",
      cta: "Teste 14 Dias Grátis",
      ctaHref: "/signup?plan=shared",
      ctaVariant: "primary" as const,
      badge: "Popular",
      popular: true,
      features: [
         "✨ Tudo do Pessoal +",
         "2 usuários",
         "Workspaces compartilhados",
         "5 GB de armazenamento",
         "Perfeito para planejar a dois",
      ],
      highlight: "Ideal para casais",
   },
   {
      name: "ERP",
      icon: Building2,
      tagline: "Equipes e empresas",
      price: "R$150",
      period: "/mês",
      annualPrice: "ou R$1500/ano (17% de desconto)",
      description:
         "Gestão financeira completa para equipes e empresas em crescimento.",
      cta: "Teste 7 Dias Grátis",
      ctaHref: "/signup?plan=erp",
      ctaVariant: "outline" as const,
      features: [
         "✨ Tudo do Compartilhado +",
         "Membros ilimitados",
         "Centros de custo",
         "Modelos de juros",
         "Automações",
         "Fornecedores/Contrapartes",
         "Suporte prioritário",
         "Chamada 1:1 para automações",
         "API access",
         "Armazenamento ilimitado",
      ],
      highlight: "Mais completo",
   },
];
---

<section id="pricing" class="py-16 md:py-24 bg-muted/50">
   <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-12 md:mb-16">
         <span class="text-primary text-sm font-medium uppercase tracking-wider">
            Preços
         </span>
         <h2 class="mt-4 text-2xl font-semibold md:text-3xl lg:text-4xl">
            Preços Simples. Sem Surpresas.
         </h2>
         <p class="mt-4 text-muted-foreground text-lg max-w-2xl mx-auto">
            Do gratis para sempre ao plano empresarial. Evolua conforme suas necessidades crescem.
         </p>
      </div>

      <!-- Pricing Cards -->
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8 max-w-7xl mx-auto mb-12">
         {plans.map((plan) => {
            const Icon = plan.icon;
            const isPopular = plan.popular;

            return (
               <div class={`relative flex flex-col p-6 md:p-8 rounded-2xl bg-background transition-all ${
                  isPopular
                     ? 'border-2 border-primary shadow-xl shadow-primary/10 md:scale-105 md:-mt-4 md:mb-4'
                     : 'border border-border/50 hover:border-primary/30'
               }`}>
                  {plan.badge && (
                     <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 text-xs font-medium rounded-full bg-primary text-primary-foreground whitespace-nowrap">
                        {plan.badge}
                     </div>
                  )}

                  {/* Header */}
                  <div class="mb-6">
                     <div class={`inline-flex items-center justify-center w-12 h-12 rounded-xl mb-4 ${
                        isPopular ? 'bg-primary/10' : 'bg-muted'
                     }`}>
                        <Icon class={`w-6 h-6 ${isPopular ? 'text-primary' : 'text-foreground'}`} />
                     </div>
                     <h3 class="text-2xl font-bold text-foreground">{plan.name}</h3>
                     <p class="text-sm text-primary font-medium mt-1">{plan.tagline}</p>
                  </div>

                  {/* Price */}
                  <div class="mb-4">
                     <div class="flex items-baseline gap-1">
                        <span class="text-4xl font-bold text-foreground">{plan.price}</span>
                        <span class="text-muted-foreground">{plan.period}</span>
                     </div>
                     {plan.annualPrice && (
                        <p class="text-sm text-muted-foreground mt-2">
                           {plan.annualPrice}
                        </p>
                     )}
                     {plan.highlight && (
                        <p class="text-xs text-primary font-medium mt-2">
                           💡 {plan.highlight}
                        </p>
                     )}
                  </div>

                  {/* Description */}
                  <p class="text-sm text-muted-foreground mb-6 min-h-[48px]">
                     {plan.description}
                  </p>

                  {/* CTA */}
                  <a
                     href={plan.ctaHref}
                     class={`flex items-center justify-center gap-2 w-full px-6 py-3 rounded-xl font-medium transition-colors mb-6 ${
                        plan.ctaVariant === 'primary'
                           ? 'bg-primary text-primary-foreground hover:bg-primary/90 shadow-lg shadow-primary/25'
                           : 'border-2 border-border hover:border-primary hover:bg-muted text-foreground'
                     }`}
                  >
                     {plan.cta}
                  </a>

                  {/* Self-host options for Free */}
                  {plan.selfHostOptions && (
                     <div class="pb-6 mb-6 border-b border-border">
                        <p class="text-xs text-muted-foreground mb-3 text-center font-medium">
                           Ou auto-hospede gratuitamente:
                        </p>
                        <div class="flex gap-2">
                           <a
                              href="https://github.com/montte/montte"
                              target="_blank"
                              rel="noopener noreferrer"
                              class="flex-1 flex items-center justify-center gap-2 px-3 py-2 rounded-lg border border-border hover:bg-muted transition-colors text-sm"
                           >
                              <Github class="w-4 h-4" />
                              GitHub
                           </a>
                           <a
                              href="https://vercel.com/new/clone?repository-url=https://github.com/montte/montte"
                              target="_blank"
                              rel="noopener noreferrer"
                              class="flex-1 flex items-center justify-center gap-2 px-3 py-2 rounded-lg border border-border hover:bg-muted transition-colors text-sm"
                           >
                              <Rocket class="w-4 h-4" />
                              Vercel
                           </a>
                        </div>
                     </div>
                  )}

                  {/* Features */}
                  <div class="flex-1">
                     <p class="text-xs font-semibold text-foreground uppercase tracking-wider mb-3">
                        Recursos incluídos:
                     </p>
                     <ul class="space-y-2.5 text-sm">
                        {plan.features.map((feature) => (
                           <li class="flex items-start gap-3">
                              <span class="shrink-0 mt-0.5">
                                 <Check class={`w-4 h-4 ${isPopular ? 'text-primary' : 'text-muted-foreground'}`} />
                              </span>
                              <span class="text-muted-foreground">{feature}</span>
                           </li>
                        ))}
                     </ul>

                     {plan.limitations && (
                        <div class="mt-4 pt-4 border-t border-border/50">
                           <p class="text-xs font-semibold text-muted-foreground uppercase tracking-wider mb-2">
                              Limitações:
                           </p>
                           <ul class="space-y-1.5 text-xs">
                              {plan.limitations.map((limitation) => (
                                 <li class="flex items-start gap-2 text-muted-foreground/70">
                                    <span class="shrink-0 mt-0.5">×</span>
                                    <span>{limitation}</span>
                                 </li>
                              ))}
                           </ul>
                        </div>
                     )}
                  </div>
               </div>
            );
         })}
      </div>

      <!-- Additional Info -->
      <div class="mt-12 text-center space-y-6">
         <div class="max-w-3xl mx-auto">
            <p class="text-sm text-muted-foreground">
               <strong class="text-foreground">Todos os planos pagos incluem:</strong> teste grátis de 7-14 dias
               (sem cartão necessário), cancelamento a qualquer momento, migração gratuita entre planos,
               e upgrade/downgrade imediato. <strong>Free é 100% funcional para sempre.</strong>
            </p>
         </div>

         <div class="flex flex-wrap justify-center gap-6 text-sm text-muted-foreground">
            <span class="flex items-center gap-2">
               <Check class="w-4 h-4 text-primary" />
               <strong>Open Source</strong>
            </span>
            <span class="flex items-center gap-2">
               <Check class="w-4 h-4 text-primary" />
               <strong>Self-host disponível</strong>
            </span>
            <span class="flex items-center gap-2">
               <Check class="w-4 h-4 text-primary" />
               <strong>Seus dados, suas regras</strong>
            </span>
            <span class="flex items-center gap-2">
               <Check class="w-4 h-4 text-primary" />
               <strong>Zero lock-in</strong>
            </span>
         </div>

         <div class="pt-6">
            <a href="/faq" class="text-sm text-primary hover:underline font-medium">
               Perguntas frequentes sobre preços →
            </a>
         </div>
      </div>
   </div>
</section>
