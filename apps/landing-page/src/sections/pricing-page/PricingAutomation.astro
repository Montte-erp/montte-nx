---
import { Check, Zap } from "@lucide/astro";
import { Card } from "@packages/ui/components/card";
import {
   Table,
   TableBody,
   TableCell,
   TableRow,
} from "@packages/ui/components/table";

const automationFeatures = {
   title: "Automação e Produtividade",
   description:
      "Elimine o trabalho manual repetitivo. Crie regras inteligentes que organizam suas finanças automaticamente.",
   included: {
      label: "Plano ERP",
      value: "Automações ilimitadas",
   },
   addons: [
      {
         name: "Notificações Push",
         price: "Incluso",
         isAddon: false,
      },
   ],
   features: [
      "Regras de automação por transação",
      "Categorização automática",
      "Aplicação automática de tags",
      "Atribuição de Centro de Custo",
      "Histórico de execuções",
      "Versionamento de automações",
   ],
};
---

<!-- AUTOMATION SECTION -->
<section id="automation" class="scroll-mt-24">
   <h2 class="text-foreground text-3xl font-bold mb-2">{automationFeatures.title}</h2>
   <p class="text-muted-foreground mb-8 max-w-2xl">{automationFeatures.description}</p>

   <!-- Pricing Table -->
   <Card className="mb-8 py-0 overflow-hidden">
      <Table>
         <TableBody>
            <TableRow className="bg-muted/30">
               <TableCell className="font-medium text-foreground py-4 px-6">{automationFeatures.included.label}</TableCell>
               <TableCell className="text-right text-sm font-medium text-primary py-4 px-6">{automationFeatures.included.value}</TableCell>
            </TableRow>
            {automationFeatures.addons.map((addon, index) => (
               <TableRow className={index < automationFeatures.addons.length - 1 ? "border-dashed" : "border-0"}>
                  <TableCell className="py-4 px-6">
                     <div class="flex items-center gap-2">
                        <Zap class="size-4 text-primary" />
                        <span class="text-sm">{addon.name}</span>
                     </div>
                  </TableCell>
                  <TableCell className={`text-right text-sm py-4 px-6 ${addon.isAddon ? "text-primary font-medium" : "text-muted-foreground"}`}>
                     {addon.price}
                  </TableCell>
               </TableRow>
            ))}
         </TableBody>
      </Table>
   </Card>

   <!-- Features Grid -->
   <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 text-sm">
      {automationFeatures.features.map((feature) => (
         <div class="flex items-start gap-2 py-1">
            <Check class="size-4 text-primary shrink-0 mt-0.5" />
            <span class="text-muted-foreground leading-snug">{feature}</span>
         </div>
      ))}
   </div>
</section>
