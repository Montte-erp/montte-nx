---
import { Check } from "@lucide/astro";
import { Card } from "@packages/ui/components/card";
import {
   Table,
   TableBody,
   TableCell,
   TableRow,
} from "@packages/ui/components/table";

const coreFeatures = {
   title: "Gestão Financeira Centralizada",
   description:
      "O coração do seu financeiro. Organize contas, controle transações e tenha visibilidade total sobre cada centavo que entra e sai.",
   included: {
      label: "Liberdade total",
      value: "Transações e Contas Ilimitadas",
   },
   features: [
      "Gestão completa de Receitas e Despesas",
      "Controle Multi-contas (Corrente, Poupança, Investimento)",
      "Arquivo Digital: Anexos de comprovantes",
      "Importação de Extratos Bancários (OFX/CSV)",
      "Filtros avançados por tipo, categoria, conta",
      "Busca de transações",
      "Marcar transações como transferência",
      "Duplicar transações",
   ],
};
---

<!-- CORE FEATURES SECTION -->
<section id="core" class="scroll-mt-24">
   <h2 class="text-foreground text-3xl font-bold mb-2">{coreFeatures.title}</h2>
   <p class="text-muted-foreground mb-8 max-w-2xl">{coreFeatures.description}</p>

   <!-- Pricing Table -->
   <Card className="mb-8 py-0 overflow-hidden">
      <Table>
         <TableBody>
            <TableRow className="bg-muted/30 border-b">
               <TableCell className="font-medium text-foreground py-4 px-6">{coreFeatures.included.label}</TableCell>
               <TableCell className="text-right text-sm font-medium text-primary py-4 px-6">{coreFeatures.included.value}</TableCell>
            </TableRow>
         </TableBody>
      </Table>
   </Card>

   <!-- Features Grid -->
   <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 text-sm">
      {coreFeatures.features.map((feature) => (
         <div class="flex items-start gap-2 py-1">
            <Check class="size-4 text-primary shrink-0 mt-0.5" />
            <span class="text-muted-foreground leading-snug">{feature}</span>
         </div>
      ))}
   </div>
</section>
