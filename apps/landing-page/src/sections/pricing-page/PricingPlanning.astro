---
import { Check, Zap } from "@lucide/astro";
import { Card } from "@packages/ui/components/card";
import {
   Table,
   TableBody,
   TableCell,
   TableRow,
} from "@packages/ui/components/table";

const planningFeatures = {
   title: "Planejamento e Previsibilidade",
   description:
      "Não seja pego de surpresa. Controle o futuro do seu caixa, gerencie vencimentos e acompanhe suas metas financeiras.",
   included: {
      label: "Incluso em todos os planos",
      value: "Orçamentos e Metas",
   },
   addons: [
      { name: "Gestão de Contas a Pagar/Receber", price: "Incluso" },
      { name: "Transações Recorrentes", price: "Incluso" },
      { name: "Templates de Juros (modelagem)", price: "Pro" },
   ],
   features: [
      "Criar e gerenciar orçamentos",
      "Acompanhamento de metas financeiras",
      "Contas a pagar e receber",
      "Gestão de vencimentos",
      "Status de pagamento (Agendado, Pago, Atrasado)",
      "Transações recorrentes",
   ],
};
---

<!-- PLANNING SECTION -->
<section id="planning" class="scroll-mt-24">
   <h2 class="text-foreground text-3xl font-bold mb-2">{planningFeatures.title}</h2>
   <p class="text-muted-foreground mb-8 max-w-2xl">{planningFeatures.description}</p>

   <!-- Pricing Table -->
   <Card className="mb-8 py-0 overflow-hidden">
      <Table>
         <TableBody>
            <TableRow className="bg-muted/30">
               <TableCell className="font-medium text-foreground py-4 px-6">{planningFeatures.included.label}</TableCell>
               <TableCell className="text-right text-sm font-medium text-primary py-4 px-6">{planningFeatures.included.value}</TableCell>
            </TableRow>
            {planningFeatures.addons.map((addon, index) => (
               <TableRow className={index < planningFeatures.addons.length - 1 ? "border-dashed" : "border-0"}>
                  <TableCell className="py-4 px-6">
                     <div class="flex items-center gap-2">
                        <Zap class="size-4 text-primary" />
                        <span class="text-sm">{addon.name}</span>
                     </div>
                  </TableCell>
                  <TableCell className="text-right text-sm text-muted-foreground py-4 px-6">{addon.price}</TableCell>
               </TableRow>
            ))}
         </TableBody>
      </Table>
   </Card>

   <!-- Features Grid -->
   <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 text-sm">
      {planningFeatures.features.map((feature) => (
         <div class="flex items-start gap-2 py-1">
            <Check class="size-4 text-primary shrink-0 mt-0.5" />
            <span class="text-muted-foreground leading-snug">{feature}</span>
         </div>
      ))}
   </div>
</section>
