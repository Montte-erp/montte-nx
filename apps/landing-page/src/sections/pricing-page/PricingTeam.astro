---
import { ArrowRight, Check } from "@lucide/astro";
import { Badge } from "@packages/ui/components/badge";
import { Button } from "@packages/ui/components/button";
import {
   Card,
   CardAction,
   CardContent,
   CardDescription,
   CardHeader,
   CardTitle,
} from "@packages/ui/components/card";
---

<!-- TEAM SECTION -->
<section id="team" class="scroll-mt-24">
   <h2 class="text-foreground text-3xl font-bold mb-2">Gestão de Time e Acessos</h2>
   <p class="text-muted-foreground mb-8 max-w-2xl">
      Delegue o operacional sem perder o controle. Convide sócios, assistentes e contadores com permissões personalizadas.
   </p>

   <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <!-- Card 1: FREE -->
      <Card className="bg-card/50">
         <CardHeader>
            <CardTitle className="text-lg">Free</CardTitle>
            <CardDescription>Para uso individual</CardDescription>
         </CardHeader>
         <CardContent>
            <div class="flex items-baseline gap-1 mb-6">
               <span class="text-foreground text-4xl font-bold tracking-tighter">R$0</span>
               <span class="text-sm text-muted-foreground">/mês</span>
            </div>
            <ul class="space-y-3 text-sm text-muted-foreground">
               <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-muted-foreground"></div>1 Usuário</li>
               <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-muted-foreground"></div>1 Workspace</li>
               <li class="flex items-center gap-2"><div class="w-1.5 h-1.5 rounded-full bg-muted-foreground"></div>Segurança Padrão</li>
            </ul>
         </CardContent>
      </Card>

      <!-- Card 2: Básico -->
      <Card className="border-primary/40 shadow-lg shadow-primary/5 relative overflow-visible">
         <Badge className="absolute -top-3 left-6 uppercase tracking-wide">
            Recomendado
         </Badge>
         <CardHeader>
            <CardTitle className="text-lg">Básico</CardTitle>
            <CardDescription>Para casais e equipes pequenas</CardDescription>
         </CardHeader>
         <CardContent>
            <div class="flex items-baseline gap-1 mb-6">
               <span class="text-foreground text-4xl font-bold tracking-tighter">
                  <span class="price-monthly">R$19</span>
                  <span class="price-yearly hidden">R$16</span>
               </span>
               <span class="text-sm text-muted-foreground">/mês</span>
            </div>
            <ul class="space-y-3 text-sm text-foreground/80 font-medium">
               <li class="flex items-center gap-2"><Check class="size-4 text-primary" /> 2 Usuários inclusos</li>
               <li class="flex items-center gap-2"><Check class="size-4 text-primary" /> Colaboração em tempo real</li>
               <li class="flex items-center gap-2"><Check class="size-4 text-primary" /> IA (em breve)</li>
            </ul>
         </CardContent>
      </Card>

      <!-- Card 3: ERP -->
      <Card className="bg-card/50">
         <CardHeader>
            <CardTitle className="text-lg">ERP</CardTitle>
            <CardDescription>Para empresas em crescimento</CardDescription>
         </CardHeader>
         <CardContent>
            <div class="flex items-baseline gap-1 mb-6">
               <span class="text-foreground text-4xl font-bold tracking-tighter">
                  <span class="price-monthly">R$150</span>
                  <span class="price-yearly hidden">R$125</span>
               </span>
               <span class="text-sm text-muted-foreground">/mês</span>
            </div>
            <ul class="space-y-3 text-sm text-foreground/80 font-medium">
               <li class="flex items-center gap-2"><Check class="size-4 text-primary" /> Membros ilimitados</li>
               <li class="flex items-center gap-2"><Check class="size-4 text-primary" /> Workspaces ilimitados</li>
               <li class="flex items-center gap-2"><Check class="size-4 text-primary" /> Logs de auditoria</li>
            </ul>
         </CardContent>
      </Card>
   </div>

   <!-- Enterprise CTA -->
   <Card className="mt-6 border-dashed bg-muted/20 py-5">
      <CardContent className="flex flex-col sm:flex-row items-center justify-between gap-4 py-0">
         <p class="text-sm text-muted-foreground">
            <span class="font-medium text-foreground">Precisa de mais recursos?</span> No plano ERP você tem membros ilimitados, workspaces ilimitados e logs de auditoria completos.
         </p>
         <Button asChild variant="link" className="shrink-0 text-primary">
            <a href="/enterprise">
               Ver Enterprise
               <ArrowRight class="size-4" />
            </a>
         </Button>
      </CardContent>
   </Card>
</section>
