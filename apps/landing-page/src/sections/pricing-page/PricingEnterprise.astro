---
import { Check, Headset, ShieldCheck } from "@lucide/astro";
---

<!-- ENTERPRISE SECTION -->
<section id="enterprise" class="scroll-mt-24">
   <h2 class="text-foreground text-3xl font-bold mb-8">Segurança e Suporte</h2>

   <!-- Security Subsection -->
   <div class="mb-12">
       <div class="flex items-center gap-3 mb-2">
           <ShieldCheck class="size-6 text-primary" />
           <h3 class="text-foreground text-xl font-bold">Segurança</h3>
       </div>
       <p class="text-muted-foreground mb-6 max-w-2xl">
          Proteção total dos seus dados com as melhores práticas de segurança.
       </p>

      <div class="rounded-xl border border-border bg-card overflow-hidden mb-6">
          {[
             { name: "Login Seguro (Senha, Google OAuth, Magic Link)", price: "Incluso" },
             { name: "Autenticação de Dois Fatores (2FA)", price: "Incluso" },
             { name: "Criptografia AES-256", price: "Incluso" },
             { name: "Gestão de sessões", price: "Incluso" },
          ].map((tier, index) => (
            <div class={`flex flex-col sm:flex-row sm:items-center justify-between px-6 py-4 gap-2 ${index < 3 ? 'border-b border-dashed border-border' : ''}`}>
               <span class="text-sm font-medium">{tier.name}</span>
               <span class="text-sm text-muted-foreground">
                  {tier.price}
               </span>
            </div>
         ))}
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-3 text-sm">
          {[
             "Verificação de e-mail",
             "Recuperação segura de senha",
             "Encerramento de sessões",
          ].map((feature) => (
            <div class="flex items-start gap-2 py-1">
               <Check class="size-4 text-primary shrink-0 mt-0.5" />
               <span class="text-muted-foreground leading-snug">{feature}</span>
            </div>
         ))}
      </div>
   </div>

   <!-- Support Subsection -->
   <div>
       <div class="flex items-center gap-3 mb-2">
           <Headset class="size-6 text-primary" />
           <h3 class="text-foreground text-xl font-bold">Suporte</h3>
       </div>
       <p class="text-muted-foreground mb-6 max-w-2xl">
          Estamos aqui para ajudar você a aproveitar ao máximo a plataforma.
       </p>

       <div class="rounded-xl border border-border bg-card overflow-hidden mb-6">
          {[
             { name: "Suporte via E-mail", price: "Incluso" },
             { name: "Documentação completa", price: "Incluso" },
         ].map((tier, index) => (
            <div class={`flex flex-col sm:flex-row sm:items-center justify-between px-6 py-4 gap-2 ${index < 1 ? 'border-b border-dashed border-border' : ''}`}>
               <span class="text-sm font-medium">{tier.name}</span>
               <span class="text-sm text-muted-foreground">
                  {tier.price}
               </span>
            </div>
         ))}
      </div>
   </div>
</section>
