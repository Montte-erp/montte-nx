---
import { FeatureCarousel } from "@/components/feature-carousel";

const workspaceFeatures = [
   {
      id: "multiplas-organizacoes",
      title: "Multiplas Organizacoes",
      description:
         "Gerencie financas pessoais e empresariais separadamente. Alterne entre workspaces com um clique, sem misturar dados.",
      image: "https://placehold.co/350x478/151925/22c55e?text=Multi+Org",
      width: "narrow" as const,
   },
   {
      id: "convites-time",
      title: "Convites e Time",
      description:
         "Convide socios, contadores e colaboradores por e-mail. Cada pessoa acessa com suas proprias credenciais.",
      image: "https://placehold.co/725x478/151925/22c55e?text=Convites+Time",
      width: "wide" as const,
   },
   {
      id: "permissoes-conta",
      title: "Permissoes por Conta",
      description:
         "Defina quem pode ver ou editar cada conta bancaria. Proteja informacoes sensiveis com controle granular de acesso.",
      image: "https://placehold.co/350x478/151925/22c55e?text=Permissoes",
      width: "narrow" as const,
   },
   {
      id: "automacoes",
      title: "Automacoes",
      description:
         "Crie regras para categorizar transacoes automaticamente. Economize tempo com fluxos de trabalho inteligentes.",
      image: "https://placehold.co/725x478/151925/22c55e?text=Automacoes",
      width: "wide" as const,
   },
];
---

<section id="workspaces" class="py-16 md:py-24 overflow-hidden relative">
   <FeatureCarousel
      items={workspaceFeatures}
      badge="Colaboracao e Seguranca"
      title="Trabalhe em equipe. Com seguranca."
      subtitle="Compartilhe o acesso com seu time mantendo o controle. Permissoes granulares e criptografia para proteger seus dados."
      ctaText="Ver planos para equipes"
      ctaHref="#pricing"
      benefitText="Colaboracao sem comprometer a seguranca."
      client:load
   />
</section>
