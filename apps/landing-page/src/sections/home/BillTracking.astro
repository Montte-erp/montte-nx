---
import { FeatureCarousel } from "@/components/feature-carousel";

const billFeatures = [
   {
      title: "Contas a Pagar",
      description:
         "Gerencie todas as suas despesas futuras em um so lugar. Filtre por status, categoria ou fornecedor e nunca perca um vencimento.",
      image: "https://placehold.co/350x478/151925/22c55e?text=Contas+a+Pagar",
      width: "narrow" as const,
   },
   {
      title: "Contas a Receber",
      description:
         "Acompanhe suas receitas previstas. Visualize estatisticas de recebimentos e mantenha o controle do seu fluxo de caixa.",
      image: "https://placehold.co/725x478/151925/22c55e?text=Contas+a+Receber",
      width: "wide" as const,
   },
   {
      title: "Parcelamentos",
      description:
         "Cadastre compras parceladas com facilidade. Visualize todas as parcelas futuras e acompanhe o valor total do compromisso.",
      image: "https://placehold.co/350x478/151925/22c55e?text=Parcelamentos",
      width: "narrow" as const,
   },
   {
      title: "Contas Recorrentes",
      description:
         "Configure contas que se repetem automaticamente. Aluguel, assinaturas e mensalidades lancados sem esforco.",
      image: "https://placehold.co/725x478/151925/22c55e?text=Recorrencias",
      width: "wide" as const,
   },
   {
      title: "Baixa em Lote",
      description:
         "Pague multiplas contas de uma vez. Selecione as contas vencidas ou a vencer e registre o pagamento em massa.",
      image: "https://placehold.co/350x478/151925/22c55e?text=Baixa+em+Lote",
      width: "narrow" as const,
   },
];
---

<section id="bills" class="py-16 md:py-24 overflow-hidden relative">


   <FeatureCarousel
      client:load
      label="Contas a Pagar e Receber"
      title="Previsibilidade no seu fluxo de caixa."
      description="Saiba exatamente o que entra e o que sai do seu caixa nos proximos meses. Evite surpresas e multas por atraso."
      ctaText="Ver ferramentas de planejamento"
      ctaHref="/features/bill-tracking"
      benefitStatement="Planeje seu futuro financeiro com confianca."
      items={billFeatures as any}
   />
</section>
