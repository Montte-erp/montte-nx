---
import { FeatureCarousel } from "@/components/feature-carousel";

const transactionFeatures = [
   {
      title: "Lancamento Rapido",
      description:
         "Adicione transacoes em segundos pelo celular ou desktop. Interface otimizada para entrada de dados com categorias e tags inteligentes.",
      image: "https://placehold.co/350x478/151925/22c55e?text=Lancamento+Rapido",
      width: "narrow" as const,
   },
   {
      title: "Rateio de Categorias",
      description:
         "Divida uma unica transacao entre multiplas categorias. Perfeito para compras com itens de diferentes naturezas ou centros de custo.",
      image: "https://placehold.co/725x478/151925/22c55e?text=Rateio+de+Categorias",
      width: "wide" as const,
   },
   {
      title: "Anexos e Comprovantes",
      description:
         "Anexe notas fiscais, recibos e comprovantes diretamente nas transacoes. Mantenha tudo organizado e acessivel para auditorias.",
      image: "https://placehold.co/350x478/151925/22c55e?text=Anexos",
      width: "narrow" as const,
   },
   {
      title: "Importacao CSV e OFX",
      description:
         "Importe extratos de qualquer banco brasileiro via arquivos CSV ou OFX. Mapeamento inteligente de colunas e deteccao de duplicatas.",
      image: "https://placehold.co/725x478/151925/22c55e?text=Importacao+CSV+OFX",
      width: "wide" as const,
   },
   {
      title: "Filtros e Estatisticas",
      description:
         "Filtre transacoes por periodo, tipo, categoria ou conta bancaria. Visualize estatisticas de receitas e despesas em tempo real.",
      image: "https://placehold.co/350x478/151925/22c55e?text=Filtros+Stats",
      width: "narrow" as const,
   },
];
---

<section id="transactions" class="py-16 md:py-24 overflow-hidden relative">


   <FeatureCarousel
      client:load
      label="Gestao de Transacoes"
      title="Controle total das suas movimentacoes."
      description="Registre, categorize e acompanhe todas as suas transacoes financeiras com ferramentas pensadas para agilidade e precisao."
      ctaText="Ver todas as features"
      ctaHref="/features/smart-transactions"
      benefitStatement="Suas financas organizadas em um unico lugar."
      items={transactionFeatures as any}
   />
</section>
