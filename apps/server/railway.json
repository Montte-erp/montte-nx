{
   "$schema": "https://railway.com/railway.schema.json",
   "build": {
      "builder": "RAILPACK",
      "buildCommand": "bun run --filter=server build",
      "watchPatterns": ["/apps/server/**", "/packages/**", "/core/**", "/libraries/**"]
   },
   "deploy": {
      "startCommand": "bun run --filter=server start",
      "multiRegionConfig": {
         "us-east4-eqdc4a": {
            "numReplicas": 1
         }
      },
      "numReplicas": 1,
      "restartPolicyMaxRetries": 10,
      "restartPolicyType": "ON_FAILURE",
      "runtime": "V2",
      "sleepApplication": true
   }
}
