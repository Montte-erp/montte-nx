{
   "name": "server",
   "version": "0.8.1",
   "license": "Apache-2.0",
   "scripts": {
      "build": "bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server ./src/index.ts",
      "check": "oxlint .",
      "container-start": "(command -v podman-compose > /dev/null 2>&1 && podman-compose -f ../web/docker-compose.yml down && podman-compose -f ../web/docker-compose.yml up -d) || (docker-compose -f ../web/docker-compose.yml down && docker-compose -f ../web/docker-compose.yml up -d)",
      "dev": "bun run container-start && bun run --watch src/index.ts",
      "start": "./server",
      "typecheck": "tsgo"
   },
   "dependencies": {
      "@core/authentication": "workspace:*",
      "@core/database": "workspace:*",
      "@core/environment": "workspace:*",
      "@core/files": "workspace:*",
      "@core/logging": "workspace:*",
      "@core/posthog": "workspace:*",
      "@core/stripe": "workspace:*",
      "@core/transactional": "workspace:*",
      "@elysiajs/cors": "catalog:server",
      "@montte/cli": "workspace:*",
      "@orpc/server": "catalog:orpc",
      "@packages/events": "workspace:*",
      "elysia": "catalog:server"
   },
   "devDependencies": {
      "@tooling/typescript": "workspace:*",
      "@types/bun": "latest",
      "typescript": "catalog:development"
   }
}
