{
   "name": "server",
   "version": "0.8.1",
   "license": "Apache-2.0",
   "scripts": {
      "build": "dotenv -e ../web/.env.local -- bun build --compile --minify-whitespace --minify-syntax --target bun --outfile server --external @tanstack/react-start --external @tanstack/start-server-core --external winston --external winston-transport ./src/index.ts",
      "check": "oxlint .",
      "wait-pg": "until pg_isready -h localhost -p 5432 -q; do sleep 1; done",
      "dev": "bun run wait-pg && dotenv -e ../web/.env.local -- bun run --watch src/index.ts",
      "start": "./server",
      "typecheck": "tsgo"
   },
   "dependencies": {
      "@core/authentication": "workspace:*",
      "@core/database": "workspace:*",
      "@core/environment": "workspace:*",
      "@core/files": "workspace:*",
      "@core/logging": "workspace:*",
      "@core/posthog": "workspace:*",
      "@core/stripe": "workspace:*",
      "@core/transactional": "workspace:*",
      "@dbos-inc/dbos-sdk": "catalog:workers",
      "@elysiajs/cors": "catalog:server",
      "@montte/cli": "workspace:*",
      "@montte/hyprpay": "workspace:*",
      "@orpc/server": "catalog:orpc",
      "@packages/events": "workspace:*",
      "@packages/notifications": "workspace:*",
      "@tanstack/ai": "catalog:tanstack-ai",
      "@tanstack/ai-openrouter": "catalog:tanstack-ai",
      "elysia": "catalog:server",
      "neverthrow": "catalog:validation"
   },
   "devDependencies": {
      "@tooling/typescript": "workspace:*",
      "@types/bun": "latest",
      "dotenv-cli": "catalog:environment",
      "typescript": "catalog:development"
   }
}
