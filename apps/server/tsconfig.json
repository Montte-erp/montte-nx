{
   "extends": "@tooling/typescript/app.json",
   "compilerOptions": {
      "experimentalDecorators": true,
      "paths": {
         "@api/*": ["./src/*"],
         "@core/authentication/*": ["../../core/authentication/src/*"],
         "@core/database": ["../../core/database/src/index.ts"],
         "@core/database/*": ["../../core/database/src/*"],
         "@core/environment/*": ["../../core/environment/src/*"],
         "@core/files/*": ["../../core/files/src/*"],
         "@core/logging": ["../../core/logging/src/logger.ts"],
         "@core/logging/*": ["../../core/logging/src/*"],
         "@core/posthog/*": ["../../core/posthog/src/*"],
         "@core/redis/*": ["../../core/redis/src/*"],
         "@core/stripe": ["../../core/stripe/src/index.ts"],
         "@core/stripe/*": ["../../core/stripe/src/*"],
         "@core/transactional/*": ["../../core/transactional/src/*"],
         "@core/utils/*": ["../../core/utils/src/*"],
         "@core/agents": ["../../core/agents/src/mastra/index.ts"],
         "@core/agents/*": ["../../core/agents/src/*"],
         "@packages/analytics/*": ["../../packages/analytics/src/*"],
         "@packages/events/*": ["../../packages/events/src/*"],
         "@packages/notifications/*": ["../../packages/notifications/src/*"],
         "@packages/ui/*": ["../../packages/ui/src/*"],
         "@montte/cli/*": ["../../libraries/cli/src/*"],
         "@montte/hyprpay": ["../../libraries/hyprpay/src/index.ts"],
         "@montte/hyprpay/contract": [
            "../../libraries/hyprpay/src/contract.ts"
         ],
         "@montte/hyprpay/better-auth": [
            "../../libraries/hyprpay/src/better-auth/index.ts"
         ]
      }
   },
   "include": ["src"],
   "references": [
      {
         "path": "../../core/redis"
      },
      {
         "path": "../../packages/events"
      },
      {
         "path": "../../libraries/cli"
      },
      {
         "path": "../../core/transactional"
      },
      {
         "path": "../../core/stripe"
      },
      {
         "path": "../../core/posthog"
      },
      {
         "path": "../../core/logging"
      },
      {
         "path": "../../core/files"
      },
      {
         "path": "../../core/environment"
      },
      {
         "path": "../../core/database"
      },
      {
         "path": "../../packages/analytics"
      },
      {
         "path": "../../packages/notifications"
      }
   ]
}
