{
   "name": "@modules/billing",
   "version": "0.1.0",
   "private": true,
   "license": "Apache-2.0",
   "type": "module",
   "exports": {
      "./router/*": "./src/router/*.ts",
      "./contracts/*": "./src/contracts/*.ts",
      "./workflows/*": "./src/workflows/*.ts",
      "./*": "./src/*.ts"
   },
   "scripts": {
      "check": "oxlint ./src",
      "format": "oxfmt --write ./src",
      "format:check": "oxfmt --check ./src",
      "test": "vitest run --passWithNoTests",
