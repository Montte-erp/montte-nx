      "bun-types": "latest",
      "cac": "^6.7.14",
      "dotenv": "catalog:environment",
      "lefthook": "^2.1.4",
      "nitro": "3.0.260311-beta",
      "nx": "22.6.3",
      "oxfmt": "^0.42.0",
