      "@vitejs/plugin-react": "catalog:vite",
      "@vitest/coverage-v8": "catalog:testing",
      "bun-types": "^1.3.12",
      "cac": "^7.0.0",
      "dotenv": "^17.4.2",
      "lefthook": "^2.1.6",
      "nitro": "3.0.260415-beta",
      "nx": "22.6.5",
      "oxfmt": "^0.45.0",
      "oxlint": "^1.60.0",
      "typescript": "^6.0.3",
      "vite-tsconfig-paths": "catalog:vite",
      "vitest": "catalog:testing"
