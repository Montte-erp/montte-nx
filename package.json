   "type": "module",
   "scripts": {
      "auth:generate": "nx run @core/authentication:auth-schema-generate",
      "build": "nx run-many -t build --parallel=3",
      "check": "oxlint .",
      "check-boundaries": "bun run tooling/boundary/check-boundaries.ts",
      "clean": "bun run scripts/clean.ts clean",
      "clean:cache": "bun run scripts/clean.ts cache",
      "db:push": "bun run scripts/ensure-schemas.ts && nx run core/database:db-push-local",
      "db:push:prod": "bun run scripts/ensure-schemas.ts --env production && nx run core/database:db-push-prod",
      "db:studio:local": "nx run core/database:db-studio-local",
      "db:studio:prod": "nx run core/database:db-studio-prod",
      "dev": "bun run scripts/dev-init.ts; nx run-many -t dev --parallel=3 -p web worker",
      "dev:staging": "bun run scripts/check-env.ts --env staging && nx run-many -t dev:staging --parallel=3 -p web",
      "setup": "bun run scripts/setup.ts",
      "dev:all": "bun run scripts/dev-init.ts && nx run-many -t dev --parallel=6",
      "doctor": "bun run scripts/doctor.ts",
      "seed:events": "bun run scripts/seed-event-catalog.ts run",
      "seed:addons": "bun run scripts/seed-addons.ts run",
      "setup:stripe": "bun run scripts/setup-stripe.ts run",
      "format": "oxfmt --write .",
      "format:check": "oxfmt --check .",
      "prepare": "lefthook install || true",
      "release": "nx release",
      "release:changelog": "nx release changelog",
      "release:dry": "nx release --dry-run --first-release",
      "release:libraries": "bun run scripts/release-library.ts",
      "release:publish": "nx release publish",
      "release:version": "nx release version",
      "reset": "bun run scripts/clean.ts reset",
      "test": "nx run-many -t test --parallel=3",
      "test:scripts": "vitest run __tests__/workspace-scripts.test.ts",
      "test:coverage": "nx run-many -t test --parallel=3 -- --coverage",
      "typecheck": "nx run-many -t typecheck --parallel=8",
      "web:build": "nx run web:build",
      "web:start": "bun run --filter=web start",
      "worker:build": "nx run worker:build",
      "worker:start": "bun run --filter=worker start"
   },
   "devDependencies": {
      "@nx/js": "22.6.5",
      "@rolldown/plugin-babel": "^0.2.3",
