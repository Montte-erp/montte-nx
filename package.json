      "type": "git",
      "url": "https://github.com/F-O-T/contentta-nx.git"
   },
   "scripts": {
      "auth:generate": "nx run authentication:auth-schema-generate",
      "build": "nx run-many -t build --parallel=3",
      "check": "nx run-many -t check --parallel=3",
      "clean": "bun run scripts/clean.ts clean",
      "clean:cache": "bun run scripts/clean.ts cache",
      "db:push": "nx run database:db-push-local",
      "db:push:prod": "nx run database:db-push-prod",
      "db:studio:local": "nx run database:db-studio-local",
      "db:studio:prod": "nx run database:db-studio-prod",
      "dev": "cd apps/web && bun run container-start && cd ../.. && bun run scripts/seed-event-catalog.ts run --env local && nx run-many -t dev --parallel=3 -p web",
      "dev:all": "bun run scripts/seed-event-catalog.ts run --env local && nx run-many -t dev --parallel=6",
      "dev:blog": "nx run-many -t dev --parallel=1 -p  blog ",
      "dev:content-apps": "nx run-many -t dev --parallel=3 -p  landing-page blog docs",
      "dev:docs": "nx run-many -t dev --parallel=1 -p  docs",
      "dev:landing-page": "nx run-many -t dev --parallel=1 -p  landing-page ",
      "dev:mastra": "nx run-many -t dev --parallel=1 -p agents",
      "dev:sdk-blog": "nx run-many -t dev --parallel=2 -p blog server",
      "dev:server": "nx run-many -t dev --parallel=1 -p server ",
      "dev:worker": "bun run scripts/seed-event-catalog.ts run --env local && nx run worker:dev",
      "doctor": "bun run scripts/doctor.ts",
      "seed:events": "bun run scripts/seed-event-catalog.ts",
      "format": "biome check --write .",
      "prepare": "husky",
      "rag:reindex": "bun run scripts/reindex-content.ts",
      "release": "nx release",
      "release:changelog": "nx release changelog",
      "release:dry": "nx release --dry-run --first-release",
      "release:libraries": "bun run scripts/release-library.ts",
      "release:publish": "nx release publish",
      "release:version": "nx release version",
      "reset": "bun run scripts/clean.ts reset",
      "start:dashboard": "nx run dashboard:start",
      "test": "nx run-many -t test --parallel=3",
      "typecheck": "nx run-many -t typecheck --parallel=8",
      "web:build": "bun run --filter=web build",
      "web:start": "bun run --filter=web start"
   },
   "trustedDependencies": [
      "@parcel/watcher",
