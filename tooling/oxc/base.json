{
   "$schema": "../../node_modules/oxlint/configuration_schema.json",
   "plugins": ["typescript", "react", "import"],
   "jsPlugins": [
      {
         "name": "react-doctor",
         "specifier": "oxlint-plugin-react-doctor"
      }
   ],
   "categories": {
      "correctness": "warn"
   },
   "rules": {
      "no-console": "warn",
      "no-debugger": "error",
      "no-unused-vars": "warn",
      "no-undef": "off",
      "react-doctor/no-fetch-in-effect": "warn",
      "react-doctor/no-derived-state-effect": "warn"
   }
}
