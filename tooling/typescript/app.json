{
   "$schema": "https://json.schemastore.org/tsconfig",
   "extends": "./base.json",
   "compilerOptions": {
      "noEmit": true,
      "jsx": "react-jsx",
      "lib": ["ES2022", "DOM", "DOM.Iterable"],
      "noUnusedLocals": true,
      "noUnusedParameters": true,
      "noFallthroughCasesInSwitch": true
   },
   "exclude": ["node_modules", "dist"]
}
