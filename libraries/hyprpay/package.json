{
   "name": "@montte/hyprpay",
   "version": "0.6.0",
   "private": false,
   "description": "HyprPay SDK — sincronize o ciclo de vida de clientes com o Montte",
   "keywords": [
      "tanstack-intent"
   ],
   "bin": {
      "hyprpay": "./dist/esm/cli/index.js"
   },
   "files": [
      "dist",
      "skills",
      "!skills/_artifacts"
   ],
   "type": "module",
   "exports": {
      ".": {
         "import": {
            "types": "./dist/esm/index.d.ts",
            "default": "./dist/esm/index.js"
         },
         "require": {
            "types": "./dist/cjs/index.d.cts",
            "default": "./dist/cjs/index.cjs"
         }
      },
      "./database/drizzle": {
         "import": {
            "types": "./dist/esm/database/drizzle.d.ts",
            "default": "./dist/esm/database/drizzle.js"
         },
         "require": {
            "types": "./dist/cjs/database/drizzle.d.cts",
            "default": "./dist/cjs/database/drizzle.cjs"
         }
      },
      "./package.json": "./package.json"
   },
   "publishConfig": {
      "access": "public"
   },
   "scripts": {
      "build": "vite build && bun run scripts/build-subpaths.ts && publint --strict",
      "test": "vitest run --passWithNoTests --exclude 'dist/**'",
      "typecheck": "tsc --noEmit"
   },
   "dependencies": {
      "@orpc/client": "catalog:orpc",
      "@orpc/contract": "catalog:orpc",
      "@orpc/server": "catalog:orpc",
      "commander": "^12.0.0",
      "jiti": "^2.6.1",
      "neverthrow": "^8.1.1",
      "zod": "4.3.6"
   },
   "devDependencies": {
      "@electric-sql/pglite": "0.3.16",
      "@tanstack/vite-config": "0.5.2",
      "@types/bun": "latest",
      "@types/node": "^20.0.0",
      "drizzle-orm": "catalog:database",
      "esbuild": "^0.25.4",
      "publint": "latest",
      "typescript": "catalog:development",
      "vite": "catalog:vite",
      "vitest": "catalog:testing"
   },
   "peerDependencies": {
      "drizzle-orm": "catalog:database"
   },
   "peerDependenciesMeta": {
      "drizzle-orm": {
         "optional": true
      }
   },
   "intent": {
      "skills": [
         "./skills/hyprpay/SKILL.md"
      ]
   }
}
