{
   "name": "@montte/hyprpay",
   "version": "0.4.1",
   "private": false,
   "description": "HyprPay SDK — sincronize o ciclo de vida de clientes com o Montte",
   "keywords": [
      "tanstack-intent"
   ],
   "files": [
      "dist",
      "skills",
      "!skills/_artifacts"
   ],
   "type": "module",
   "exports": {
      ".": {
         "import": {
            "types": "./dist/esm/index.d.ts",
            "default": "./dist/esm/index.js"
         },
         "require": {
            "types": "./dist/cjs/index.d.cts",
            "default": "./dist/cjs/index.cjs"
         }
      },
      "./contract": {
         "import": {
            "types": "./dist/esm/contract.d.ts",
            "default": "./dist/esm/contract.js"
         },
         "require": {
            "types": "./dist/cjs/contract.d.cts",
            "default": "./dist/cjs/contract.cjs"
         }
      },
      "./package.json": "./package.json"
   },
   "publishConfig": {
      "access": "public"
   },
   "scripts": {
      "build": "vite build && bun run scripts/build-subpaths.ts && publint --strict",
      "test": "vitest run --passWithNoTests --exclude 'dist/**'",
      "typecheck": "tsc --noEmit"
   },
   "dependencies": {
      "@orpc/client": "catalog:orpc",
      "@orpc/contract": "catalog:orpc",
      "neverthrow": "^8.1.1",
      "zod": "4.3.6"
   },
   "devDependencies": {
      "@tanstack/vite-config": "0.5.2",
      "@types/bun": "latest",
      "better-auth": "catalog:auth",
      "esbuild": "^0.25.4",
      "publint": "latest",
      "typescript": "catalog:development",
      "vite": "catalog:vite",
      "vitest": "catalog:testing"
   },
   "intent": {
      "skills": [
         "./skills/hyprpay/SKILL.md"
      ]
   }
}
