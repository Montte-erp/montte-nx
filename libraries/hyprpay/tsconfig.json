{
   "compilerOptions": {
      "target": "ES2020",
      "module": "ESNext",
      "moduleResolution": "bundler",
      "rootDir": "./src",
      "declaration": true,
      "strict": true,
      "skipLibCheck": true,
      "noEmit": true,
      "types": ["node"]
   },
   "include": ["src/**/*"],
   "exclude": ["node_modules", "dist", "**/*.test.ts", "src/cli/**"]
}
