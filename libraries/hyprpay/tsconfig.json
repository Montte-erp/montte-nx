{
   "compilerOptions": {
      "target": "ES2020",
      "module": "ESNext",
      "moduleResolution": "bundler",
      "declaration": true,
      "emitDeclarationOnly": true,
      "outDir": "./dist/esm/src",
      "rootDir": "./src",
      "strict": true,
      "skipLibCheck": true
   },
   "include": ["src/**/*"],
   "exclude": ["node_modules", "dist", "**/*.test.ts"]
}
