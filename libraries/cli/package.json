{
   "name": "@montte/cli",
   "version": "0.1.0",
   "private": false,
   "description": "Montte CLI — manage your finances from the terminal",
   "keywords": [
      "tanstack-intent"
   ],
   "bin": {
      "montte": "./dist/esm/index.js"
   },
   "files": [
      "dist",
      "skills",
      "!skills/_artifacts"
   ],
   "type": "module",
   "exports": {
      ".": {
         "import": {
            "types": "./dist/esm/index.d.ts",
            "default": "./dist/esm/index.js"
         },
         "require": {
            "types": "./dist/cjs/index.d.cts",
            "default": "./dist/cjs/index.cjs"
         }
      },
      "./contract": {
         "import": {
            "types": "./dist/esm/contract/index.d.ts",
            "default": "./dist/esm/contract/index.js"
         },
         "require": {
            "types": "./dist/cjs/contract/index.d.cts",
            "default": "./dist/cjs/contract/index.cjs"
         }
      },
      "./package.json": "./package.json"
   },
   "publishConfig": {
      "access": "public"
   },
   "scripts": {
      "build": "vite build && bun run scripts/build-contract.ts && publint --strict",
      "publish:pkg": "bun run scripts/publish.ts",
      "test": "vitest run",
      "test:watch": "vitest",
      "typecheck": "tsgo"
   },
   "dependencies": {
      "@orpc/client": "catalog:orpc",
      "@orpc/contract": "catalog:orpc",
      "cac": "^6.7.14",
      "zod": "4.3.6"
   },
   "devDependencies": {
      "@tanstack/intent": "latest",
      "@tanstack/publish-config": "latest",
      "@tanstack/vite-config": "latest",
      "@tooling/typescript": "workspace:*",
      "@types/bun": "latest",
      "@vitest/coverage-v8": "catalog:testing",
      "publint": "latest",
      "typescript": "catalog:development",
      "vite": "catalog:vite",
      "vitest": "catalog:testing"
   }
}
