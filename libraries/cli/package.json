{
   "name": "@montte/cli",
   "version": "0.1.0",
   "private": false,
   "description": "Montte CLI — manage your finances from the terminal",
   "bin": {
      "montte": "./src/index.ts"
   },
   "files": [
      "src"
   ],
   "type": "module",
   "exports": {
      ".": {
         "types": "./src/index.ts",
         "bun": "./src/index.ts",
         "import": "./src/index.ts"
      },
      "./contract": {
         "types": "./src/contract/index.ts",
         "bun": "./src/contract/index.ts",
         "import": "./src/contract/index.ts"
      }
   },
   "publishConfig": {
      "access": "public"
   },
   "scripts": {
      "test": "vitest run",
      "test:watch": "vitest",
      "typecheck": "tsgo"
   },
   "dependencies": {
      "@orpc/client": "catalog:orpc",
      "@orpc/contract": "catalog:orpc",
      "cac": "^6.7.14",
      "zod": "4.3.6"
   },
   "devDependencies": {
      "@tooling/typescript": "workspace:*",
      "@types/bun": "latest",
      "typescript": "catalog:development",
      "vitest": "^3.2.4"
   }
}
