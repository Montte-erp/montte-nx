{
   "name": "@packages/search",
   "version": "0.1.0",
   "private": true,
   "files": [
      "dist"
   ],
   "type": "module",
   "exports": {
      ".": {
         "types": "./dist/src/index.d.ts",
         "default": "./src/index.ts"
      },
      "./types": {
         "types": "./dist/src/types.d.ts",
         "default": "./src/types.ts"
      },
      "./providers/*": {
         "types": "./dist/src/providers/*.d.ts",
         "default": "./src/providers/*.ts"
      }
   },
   "scripts": {
      "build": "tsc --build",
      "typecheck": "tsgo"
   },
   "dependencies": {
      "@core/environment": "workspace:*",
      "@core/logging": "workspace:*",
      "@core/utils": "workspace:*",
      "@mendable/firecrawl-js": "catalog:search-providers",
      "@tavily/core": "catalog:search-providers",
      "exa-js": "catalog:search-providers",
      "zod": "catalog:validation"
   },
   "devDependencies": {
      "@tooling/typescript": "workspace:*",
      "typescript": "catalog:development"
   }
}
