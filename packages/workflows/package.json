{
   "name": "@packages/workflows",
   "version": "0.1.0",
   "private": true,
   "type": "module",
   "license": "Apache-2.0",
   "scripts": {
      "build": "tsc --build",
      "test": "bun test",
      "typecheck": "tsc"
   },
   "dependencies": {
      "@f-o-t/condition-evaluator": "2.0.0",
      "@f-o-t/rules-engine": "workspace:*",
      "@packages/csv": "workspace:*",
      "@packages/database": "workspace:*",
      "@packages/pdf": "workspace:*",
      "@packages/queue": "workspace:*",
      "@packages/utils": "workspace:*",
      "zod": "catalog:validation"
   },
   "devDependencies": {
      "@tooling/typescript": "workspace:*",
      "typescript": "catalog:development"
   },
   "exports": {
      "./actions/handlers/*": {
         "default": "./src/actions/handlers/*.ts",
         "types": "./dist/src/actions/handlers/*.d.ts"
      },
      "./actions/*": {
         "default": "./src/actions/*.ts",
         "types": "./dist/src/actions/*.d.ts"
      },
      "./engine/*": {
         "default": "./src/engine/*.ts",
         "types": "./dist/src/engine/*.d.ts"
      },
      "./queue/*": {
         "default": "./src/queue/*.ts",
         "types": "./dist/src/queue/*.d.ts"
      },
      "./schemas/*": {
         "default": "./src/schemas/*.ts",
         "types": "./dist/src/schemas/*.d.ts"
      },
      "./triggers/*": {
         "default": "./src/triggers/*.ts",
         "types": "./dist/src/triggers/*.d.ts"
      },
      "./types/*": {
         "default": "./src/types/*.ts",
         "types": "./dist/src/types/*.d.ts"
      },
      "./utils/*": {
         "default": "./src/utils/*.ts",
         "types": "./dist/src/utils/*.d.ts"
      },
      "./config/actions": {
         "default": "./src/config/actions/index.ts",
         "types": "./dist/src/config/actions/index.d.ts"
      }
   },
   "files": [
      "dist"
   ]
}
