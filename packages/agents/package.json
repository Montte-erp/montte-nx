{
   "name": "@packages/agents",
   "version": "0.25.1",
   "private": true,
   "license": "Apache-2.0",
   "files": [
      "dist"
   ],
   "type": "module",
   "exports": {
      ".": {
         "types": "./dist/src/mastra/index.d.ts",
         "default": "./src/mastra/index.ts"
      },
      "./mastra": {
         "types": "./dist/src/mastra/index.d.ts",
         "default": "./src/mastra/index.ts"
      },
      "./models": {
         "types": "./dist/src/models.d.ts",
         "default": "./src/models.ts"
      },
      "./rag/*": {
         "types": "./dist/src/mastra/rag/*.d.ts",
         "default": "./src/mastra/rag/*.ts"
      }
   },
   "scripts": {
      "build": "tsc --build",
      "check": "oxlint ./src",
      "dev": "dotenv -e .env -- bunx mastra dev",
      "typecheck": "tsgo"
   },
   "dependencies": {
      "@f-o-t/markdown": "catalog:fot",
      "@mastra/ai-sdk": "catalog:mastra",
      "@mastra/core": "catalog:mastra",
      "@mastra/memory": "catalog:mastra",
      "@mastra/observability": "catalog:mastra",
      "@mastra/pg": "catalog:mastra",
      "@mastra/posthog": "catalog:mastra",
      "@mastra/rag": "catalog:mastra",
      "@packages/database": "workspace:*",
      "@packages/environment": "workspace:*",
      "@packages/files": "workspace:*",
      "@packages/search": "workspace:*",
      "@packages/utils": "workspace:*",
      "ai": "catalog:mastra",
      "zod": "catalog:validation"
   },
   "devDependencies": {
      "@tooling/typescript": "workspace:*",
      "dotenv-cli": "catalog:enviroment",
      "shx": "catalog:enviroment",
      "typescript": "catalog:development"
   }
}
