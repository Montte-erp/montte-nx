{
   "extends": "@tooling/typescript/internal-package.json",
   "compilerOptions": {
      "baseUrl": ".",
      "jsx": "preserve",
      "typeRoots": ["./node_modules", "./node_modules/@types"],
      "paths": {
         "@packages/ui/*": ["./src/*"]
      }
   },
   "include": ["src"],
   "exclude": ["**/*.test.ts", "**/__tests__/**", "node_modules"],
   "references": [
    {
      "path": "../utils/tsconfig.lib.json"
    }
  ]
}
