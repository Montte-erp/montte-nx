{
   "extends": "@tooling/typescript/tsconfig.package.json",
   "compilerOptions": {
      "paths": {
         "@core/authentication/*": ["../../core/authentication/src/*"],
         "@core/database": ["../../core/database/src/index.ts"],
         "@core/database/*": ["../../core/database/src/*"],
         "@core/environment/*": ["../../core/environment/src/*"],
         "@core/files/*": ["../../core/files/src/*"],
         "@core/logging": ["../../core/logging/src/logger.ts"],
         "@core/logging/*": ["../../core/logging/src/*"],
         "@core/posthog/*": ["../../core/posthog/src/*"],
         "@core/redis/*": ["../../core/redis/src/*"],
         "@core/stripe": ["../../core/stripe/src/index.ts"],
         "@core/stripe/*": ["../../core/stripe/src/*"],
         "@core/transactional/*": ["../../core/transactional/src/*"],
         "@core/utils/*": ["../../core/utils/src/*"],
         "@core/agents": ["../../core/agents/src/mastra/index.ts"],
         "@core/agents/*": ["../../core/agents/src/*"],
         "@packages/analytics/*": ["../../packages/analytics/src/*"],
         "@packages/events/*": ["./src/*"],
         "@packages/feedback/*": ["../../packages/feedback/src/*"],
         "@packages/ui/*": ["../../packages/ui/src/*"]
      }
   },
   "include": ["src"],
   "references": [
      {
         "path": "../../core/stripe"
      },
      {
         "path": "../../core/redis"
      },
      {
         "path": "../../core/posthog"
      },
      {
         "path": "../../core/logging"
      },
      {
         "path": "../../core/database"
      }
