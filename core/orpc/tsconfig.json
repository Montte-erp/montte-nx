{
   "extends": "@tooling/typescript/core.json",
   "compilerOptions": {
      "composite": false,
      "declaration": false,
      "declarationMap": false,
      "noEmit": true,
      "paths": {
         "@core/authentication/*": ["../../core/authentication/dist/*"],
         "@core/database": ["../../core/database/src/index.ts"],
         "@core/database/*": ["../../core/database/src/*"],
         "@core/dbos/*": ["../../core/dbos/src/*"],
         "@core/environment/*": ["../../core/environment/src/*"],
         "@core/files/*": ["../../core/files/src/*"],
         "@core/logging": ["../../core/logging/src/logger.ts"],
         "@core/logging/*": ["../../core/logging/src/*"],
         "@core/notifications/*": ["../../core/notifications/src/*"],
         "@core/posthog/*": ["../../core/posthog/src/*"],
         "@core/redis/*": ["../../core/redis/src/*"],
         "@core/utils/*": ["../../core/utils/src/*"]
      }
   },
   "references": [
      {
         "path": "../utils"
      },
      {
         "path": "../redis"
      },
      {
         "path": "../posthog"
      },
      {
         "path": "../pg-boss"
      },
      {
         "path": "../notifications"
      },
      {
         "path": "../logging"
      },
      {
         "path": "../files"
      },
      {
         "path": "../environment"
      },
      {
         "path": "../dbos"
      },
      {
         "path": "../database"
      }
   ],
   "include": ["src"]
}
