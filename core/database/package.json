{
   "name": "@core/database",
   "version": "0.12.1",
   "private": true,
   "license": "Apache-2.0",
   "files": [
      "dist"
   ],
   "type": "module",
   "exports": {
      "./client": {
         "types": "./dist/src/client.d.ts",
         "default": "./src/client.ts"
      },
      "./repositories/*": {
         "types": "./dist/src/repositories/*.d.ts",
         "default": "./src/repositories/*.ts"
      },
      "./schema": {
         "types": "./dist/src/schema.d.ts",
         "default": "./src/schema.ts"
      },
      "./relations": {
         "types": "./dist/src/relations.d.ts",
         "default": "./src/relations.ts"
      },
      "./helpers/*": {
         "types": "./dist/src/helpers/*.d.ts",
         "default": "./src/helpers/*.ts"
      },
      "./schemas/*": {
         "types": "./dist/src/schemas/*.d.ts",
         "default": "./src/schemas/*.ts"
      }
   },
   "scripts": {
      "build": "tsc --build",
      "check": "oxlint ./src",
      "format": "oxfmt --write ./src",
      "format:check": "oxfmt --check ./src",
      "test": "vitest run",
      "db-push-local": "dotenv -e .env.local drizzle-kit push",
      "db-push-prod": "dotenv -e .env.production drizzle-kit push",
      "db-studio-local": "dotenv -e .env.local drizzle-kit studio",
      "db-studio-prod": "dotenv -e .env.production drizzle-kit studio",
      "env:copy-example": "shx -- cp -n .env.example .env",
      "env:remove": "shx -- rm -f .env",
      "env:run": "dotenv -e .env.local --",
      "generate": "bun run env:run drizzle-kit generate ",
      "generate:custom": "bun run env:run drizzle-kit generate --custom",
      "migrate": "bun run env:run drizzle-kit migrate",
      "push": "bun run env:run drizzle-kit push",
      "studio": "bun run env:run drizzle-kit studio",
      "typecheck": "tsgo"
   },
   "dependencies": {
      "@core/environment": "workspace:*",
      "@core/logging": "workspace:*",
      "@core/utils": "workspace:*",
      "@f-o-t/condition-evaluator": "catalog:fot",
      "@f-o-t/money": "catalog:fot",
      "drizzle-orm": "catalog:database",
      "pg": "catalog:database",
      "zod": "catalog:validation"
   },
   "devDependencies": {
      "@electric-sql/pglite": "^0.3.15",
      "@tooling/typescript": "workspace:*",
      "@types/pg": "catalog:database",
      "dotenv-cli": "catalog:enviroment",
      "drizzle-kit": "catalog:database",
      "shx": "catalog:enviroment",
      "typescript": "catalog:development"
   }
}
