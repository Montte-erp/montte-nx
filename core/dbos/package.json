{
   "name": "@core/dbos",
   "version": "0.1.0",
   "private": true,
   "license": "Apache-2.0",
   "files": [
      "dist"
   ],
   "type": "module",
   "exports": {
      "./client": {
         "types": "./dist/client.d.ts",
         "default": "./dist/client.js"
      },
      "./worker": {
         "types": "./dist/worker.d.ts",
         "default": "./dist/worker.js"
      },
      "./factory": {
         "types": "./dist/factory.d.ts",
         "default": "./dist/factory.js"
      },
      "./errors": {
         "types": "./dist/errors.d.ts",
         "default": "./dist/errors.js"
      },
      "./testing/*": {
         "types": "./dist/testing/*.d.ts",
         "default": "./dist/testing/*.js"
      }
   },
   "scripts": {
      "build": "tsc --build",
      "check": "oxlint ./src",
      "format": "oxfmt --write ./src",
      "format:check": "oxfmt --check ./src",
      "test": "vitest run --passWithNoTests",
      "typecheck": "tsgo"
   },
   "dependencies": {
      "@core/database": "workspace:*",
      "@core/environment": "workspace:*",
      "@core/logging": "workspace:*",
      "@dbos-inc/dbos-sdk": "catalog:workers",
      "better-result": "catalog:validation",
      "winston": "^3.19.0",
      "winston-transport": "^4.9.0"
   },
   "devDependencies": {
      "@tooling/typescript": "workspace:*",
      "typescript": "catalog:development",
      "vitest": "catalog:testing"
   },
   "peerDependencies": {
      "vitest": "catalog:testing"
   },
   "peerDependenciesMeta": {
      "vitest": {
         "optional": true
      }
   }
}
