{
   "name": "@core/posthog",
   "version": "0.8.1",
   "private": true,
   "license": "Apache-2.0",
   "files": [
      "dist"
   ],
   "type": "module",
   "exports": {
      "./server": {
         "types": "./dist/src/server.d.ts",
         "default": "./src/server.ts"
