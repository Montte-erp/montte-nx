{
   "name": "@core/posthog",
   "version": "0.8.1",
   "private": true,
   "license": "Apache-2.0",
   "files": [
      "dist"
   ],
   "type": "module",
   "exports": {
      "./server": {
         "types": "./dist/server.d.ts",
         "default": "./dist/server.js"
      },
      "./config": {
         "types": "./dist/config.d.ts",
         "default": "./dist/config.js"
      },
      "./prompts": {
         "types": "./dist/prompts.d.ts",
         "default": "./dist/prompts.js"
      }
   },
   "scripts": {
      "build": "tsc --build",
      "check": "oxlint ./src",
      "format": "oxfmt --write ./src",
      "format:check": "oxfmt --check ./src",
      "test": "vitest run --passWithNoTests",
      "typecheck": "tsgo"
   },
   "dependencies": {
      "@core/environment": "workspace:*",
      "@posthog/ai": "^7.16.0",
      "neverthrow": "catalog:validation",
      "posthog-node": "catalog:analytics-client",
      "zod": "catalog:validation"
   },
   "devDependencies": {
      "@tooling/typescript": "workspace:*",
      "typescript": "catalog:development"
   }
}
