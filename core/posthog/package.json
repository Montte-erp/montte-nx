{
   "name": "@core/posthog",
   "version": "0.8.1",
   "private": true,
   "license": "Apache-2.0",
   "files": [
      "dist"
   ],
   "type": "module",
   "exports": {
      "./server": {
         "types": "./dist/server.d.ts",
         "default": "./dist/server.js"
      },
      "./surveys": {
         "types": "./dist/surveys.d.ts",
         "default": "./dist/surveys.js"
      },
      "./feature-flags": {
         "types": "./dist/feature-flags.d.ts",
         "default": "./dist/feature-flags.js"
      }
   },
   "scripts": {
      "build": "tsc --build",
      "check": "oxlint ./src",
      "format": "oxfmt --write ./src",
      "format:check": "oxfmt --check ./src",
      "test": "vitest run --passWithNoTests",
      "typecheck": "tsgo"
   },
   "dependencies": {
      "@core/environment": "workspace:*",
      "posthog-node": "catalog:analytics-client"
   },
   "devDependencies": {
      "@tooling/typescript": "workspace:*",
      "typescript": "catalog:development"
   }
}
