{
   "name": "@core/authentication",
   "version": "0.8.1",
   "private": true,
   "license": "Apache-2.0",
   "files": [
      "dist"
   ],
   "type": "module",
   "exports": {
      "./client": {
         "types": "./dist/client.d.ts",
         "default": "./dist/client.js"
      },
      "./server": {
         "types": "./dist/server.d.ts",
         "default": "./dist/server.js"
      },
      "./api-key-config": {
         "types": "./dist/api-key-config.d.ts",
         "default": "./dist/api-key-config.js"
      },
      "./cache": {
         "types": "./dist/cache.d.ts",
         "default": "./dist/cache.js"
      }
   },
   "scripts": {
      "auth-schema-generate": "npx auth generate --config ./src/cli-config.ts --output ../database/src/schemas/auth.ts",
      "build": "tsc --build",
      "check": "oxlint ./src",
      "format": "oxfmt --write ./src",
      "format:check": "oxfmt --check ./src",
      "test": "vitest run --passWithNoTests",
      "typecheck": "tsgo"
   },
   "dependencies": {
      "@better-auth/api-key": "catalog:auth",
      "@better-auth/drizzle-adapter": "catalog:auth",
      "@better-auth/stripe": "catalog:auth",
      "@core/database": "workspace:*",
      "@core/environment": "workspace:*",
      "@core/logging": "workspace:*",
      "@core/posthog": "workspace:*",
      "@core/redis": "workspace:*",
      "@core/stripe": "workspace:*",
      "@core/transactional": "workspace:*",
      "better-auth": "catalog:auth",
      "react": "catalog:react",
      "react-dom": "catalog:react"
   },
   "devDependencies": {
      "@tooling/typescript": "workspace:*",
      "typescript": "catalog:development"
   }
}
