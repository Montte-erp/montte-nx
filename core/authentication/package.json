{
   "name": "@core/authentication",
   "version": "0.8.1",
   "private": true,
   "license": "Apache-2.0",
   "files": [
      "dist"
   ],
   "type": "module",
   "exports": {
      "./client": {
         "types": "./dist/src/client.d.ts",
         "default": "./src/client.ts"
      },
      "./helpers": {
         "types": "./dist/src/helpers/index.d.ts",
         "default": "./src/helpers/index.ts"
      },
      "./server": {
         "types": "./dist/src/server.d.ts",
         "default": "./src/server.ts"
      },
      "./api-key-config": {
         "types": "./dist/src/api-key-config.d.ts",
         "default": "./src/api-key-config.ts"
      },
      "./cache": {
         "types": "./dist/src/cache.d.ts",
         "default": "./src/cache.ts"
      },
      "./redis-connection": {
         "types": "./dist/src/redis-connection.d.ts",
         "default": "./src/redis-connection.ts"
      }
   },
   "scripts": {
      "auth-schema-generate": "npx auth generate --config ./src/cli-config.ts --output ../database/src/schemas/auth.ts",
      "build": "tsc --build",
      "check": "oxlint ./src",
      "typecheck": "tsgo"
   },
   "dependencies": {
      "@better-auth/api-key": "catalog:auth",
      "@better-auth/oauth-provider": "catalog:auth",
      "@better-auth/stripe": "catalog:auth",
      "@core/database": "workspace:*",
      "@core/environment": "workspace:*",
      "@core/redis": "workspace:*",
      "@packages/stripe": "workspace:*",
      "@packages/transactional": "workspace:*",
      "better-auth": "catalog:auth",
      "ioredis": "catalog:workers",
      "react": "catalog:react",
      "react-dom": "catalog:react"
   },
   "devDependencies": {
      "@tooling/typescript": "workspace:*",
      "typescript": "catalog:development"
   }
}
