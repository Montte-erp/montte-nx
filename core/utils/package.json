      },
      "./number": {
         "types": "./dist/src/numbers.d.ts",
         "default": "./src/numbers.ts"
      },
      "./object": {
         "types": "./dist/src/object.d.ts",
         "default": "./src/object.ts"
      },
      "./permissions": {
         "types": "./dist/src/permissions.d.ts",
