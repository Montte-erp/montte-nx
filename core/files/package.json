{
   "name": "@core/files",
   "version": "0.12.0",
   "private": true,
   "license": "Apache-2.0",
   "files": [
      "dist"
   ],
   "type": "module",
   "exports": {
      "./client": {
         "types": "./dist/src/client.d.ts",
         "default": "./src/client.ts"
      },
      "./text-file-helper": {
         "types": "./dist/src/text-file-helpers.d.ts",
         "default": "./src/text-file-helpers.ts"
      }
   },
   "scripts": {
      "build": "tsc --build",
      "check": "oxlint ./src",
      "format": "oxfmt --write ./src",
      "format:check": "oxfmt --check ./src",
      "test": "vitest run --passWithNoTests",
      "typecheck": "tsgo"
   },
   "dependencies": {
      "@core/environment": "workspace:*",
      "@core/logging": "workspace:*",
      "fflate": "catalog:files",
      "minio": "catalog:files"
   },
   "devDependencies": {
      "@tooling/typescript": "workspace:*",
      "typescript": "catalog:development"
   }
}
