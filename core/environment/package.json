{
   "name": "@core/environment",
   "version": "0.8.1",
   "private": true,
   "license": "Apache-2.0",
   "files": [
      "dist"
   ],
   "type": "module",
   "exports": {
      "./web": {
         "types": "./dist/src/web.d.ts",
         "default": "./src/web.ts"
      },
      "./helpers": {
         "types": "./dist/src/helpers.d.ts",
         "default": "./src/helpers.ts"
      },
      "./worker": {
         "types": "./dist/src/worker.d.ts",
         "default": "./src/worker.ts"
      }
   },
   "scripts": {
      "build": "tsc --build",
      "check": "oxlint ./src",
      "format": "oxfmt --write ./src",
      "format:check": "oxfmt --check ./src",
      "test": "vitest run --passWithNoTests",
      "typecheck": "tsgo"
   },
   "dependencies": {
      "@core/utils": "workspace:*",
      "@t3-oss/env-core": "^0.13.8",
      "zod": "catalog:validation"
   },
   "devDependencies": {
      "@tooling/typescript": "workspace:*",
      "typescript": "catalog:development",
      "vite": "catalog:vite"
   }
}
