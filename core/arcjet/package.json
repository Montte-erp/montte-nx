{
   "name": "@core/arcjet",
   "version": "0.1.0",
   "private": true,
   "license": "Apache-2.0",
   "files": [
      "dist"
   ],
   "type": "module",
   "exports": {
      "./client": {
         "types": "./dist/src/client.d.ts",
         "default": "./src/client.ts"
      },
      "./protect": {
         "types": "./dist/src/protect.d.ts",
         "default": "./src/protect.ts"
      }
   },
   "scripts": {
      "build": "tsc --build",
      "check": "oxlint ./src",
      "format": "oxfmt --write ./src",
      "format:check": "oxfmt --check ./src",
      "test": "vitest run --passWithNoTests",
      "typecheck": "tsgo"
   },
   "dependencies": {
      "@arcjet/bun": "^1.2.0",
      "@core/environment": "workspace:*",
      "@core/logging": "workspace:*"
   },
   "devDependencies": {
      "@tooling/typescript": "workspace:*",
      "typescript": "catalog:development"
   }
}
