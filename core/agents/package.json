{
   "name": "@core/agents",
   "version": "0.25.1",
   "private": true,
   "license": "Apache-2.0",
   "files": [
      "dist"
   ],
   "type": "module",
   "exports": {
      ".": {
         "types": "./dist/mastra/index.d.ts",
         "default": "./dist/mastra/index.js"
      },
      "./mastra": {
         "types": "./dist/mastra/index.d.ts",
         "default": "./dist/mastra/index.js"
      },
      "./models": {
         "types": "./dist/models.d.ts",
         "default": "./dist/models.js"
      },
      "./utils": {
         "types": "./dist/utils.d.ts",
         "default": "./dist/utils.js"
      }
   },
   "scripts": {
      "build": "tsc --build",
      "check": "oxlint ./src",
      "env:run": "dotenv -e ../../apps/web/.env --",
      "dev": "bun run env:run bunx mastra dev",
      "typecheck": "tsgo"
   },
   "dependencies": {
      "@core/database": "workspace:*",
      "@core/environment": "workspace:*",
      "@core/logging": "workspace:*",
      "@core/utils": "workspace:*",
      "@mastra/ai-sdk": "catalog:mastra",
      "@mastra/core": "catalog:mastra",
      "@mastra/memory": "catalog:mastra",
      "@mastra/observability": "catalog:mastra",
      "@mastra/pg": "catalog:mastra",
      "@mastra/posthog": "catalog:mastra",
      "ai": "catalog:mastra",
      "zod": "catalog:validation"
   },
   "devDependencies": {
      "@tooling/typescript": "workspace:*",
      "dotenv-cli": "catalog:environment",
      "typescript": "catalog:development"
   }
}
