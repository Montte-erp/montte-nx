{
   "name": "@core/logging",
   "version": "0.1.0",
   "private": true,
   "license": "Apache-2.0",
   "files": [
      "dist"
   ],
   "type": "module",
   "exports": {
      ".": {
         "types": "./dist/logger.d.ts",
         "default": "./dist/logger.js"
      },
      "./types": {
         "types": "./dist/types.d.ts",
         "default": "./dist/types.js"
      },
      "./otel": {
         "types": "./dist/otel.d.ts",
         "default": "./dist/otel.js"
      },
      "./health": {
         "types": "./dist/health.d.ts",
         "default": "./dist/health.js"
      },
      "./root": {
         "types": "./dist/root.d.ts",
         "default": "./dist/root.js"
      },
      "./errors": {
         "types": "./dist/errors.d.ts",
         "default": "./dist/errors.js"
      }
   },
   "scripts": {
      "build": "tsc --build",
      "check": "oxlint ./src",
      "format": "oxfmt --write ./src",
      "format:check": "oxfmt --check ./src",
      "test": "vitest run",
      "typecheck": "tsgo"
   },
   "dependencies": {
      "@opentelemetry/api": "catalog:telemetry",
      "@opentelemetry/api-logs": "catalog:telemetry",
      "@opentelemetry/exporter-logs-otlp-http": "catalog:telemetry",
      "@opentelemetry/exporter-trace-otlp-http": "catalog:telemetry",
      "@opentelemetry/resources": "catalog:telemetry",
      "@opentelemetry/sdk-logs": "catalog:telemetry",
      "@opentelemetry/sdk-node": "catalog:telemetry",
      "@orpc/otel": "catalog:orpc",
      "@orpc/server": "catalog:orpc",
      "@posthog/ai": "^7.16.0",
      "evlog": "catalog:logging",
      "posthog-node": "catalog:analytics-client",
      "zod": "catalog:validation"
   },
   "devDependencies": {
      "@tooling/typescript": "workspace:*",
      "@types/node": "^20",
      "typescript": "catalog:development"
   }
}
